@page "/exam/start/{Token}"
@inject DenemeTest.Application.Exams.IExamSessionAppService ExamSessionApp
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Sınav Girişi</h3>

@if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <ol class="mb-3">
        <li>Kamera ve mikrofonuna izin ver.</li>
        <li>Önizlemeyi görüyorsan <strong>Sınava Başla</strong> aktif olur.</li>
    </ol>

    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex align-items-start gap-3 flex-wrap">
                <div>
                    <video id="previewVideo" width="320" height="240" class="border rounded"></video>
                </div>
                <div class="d-flex flex-column gap-2">
                    <button class="btn btn-outline-primary" @onclick="RequestPermission" disabled="@_granted">Kamera/Mikrofon İzni Ver</button>
                    <div>
                        Durum:
                        @if (_granted)
                        {
                            <span class="badge bg-success">İzin verildi</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Bekleniyor</span>
                        }
                    </div>
                    <small class="text-muted">Tarayıcın izin diyalogu göstermediyse sayfayı yenilemeyi dene.</small>
                </div>
            </div>
        </div>
    </div>

    <button class="btn btn-primary" @onclick="StartExam" disabled="@(!_granted)">Sınava Başla</button>
}

@code {
    [Parameter] public string Token { get; set; } = default!;
    private string? _error;
    private bool _granted = false;

    private async Task RequestPermission()
    {
        var ok = await JS.InvokeAsync<bool>("mediaGate.request");
        if (ok)
        {
            var attached = await JS.InvokeAsync<bool>("mediaGate.attachPreview", "#previewVideo");
            _granted = attached;
        }
        else
        {
            _granted = false;
        }
        StateHasChanged();
    }

    private async Task StartExam()
    {
        try
        {
            var res = await ExamSessionApp.StartByTokenAsync(Token);
            Nav.NavigateTo($"/exam/runner/{res.Id}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("mediaGate.stop"); } catch { }
    }
}
