@page "/exam/start/{Token}"
@layout Shared.ExamLayout

@inject DenemeTest.Application.Exams.IExamSessionAppService ExamSessionApp
@inject NavigationManager Nav
@inject IJSRuntime JS

@implements IAsyncDisposable

<h3 class="mb-3">Sınav Girişi</h3>

@if (_error != null)
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <div class="alert alert-info">
        Bu sayfaya girdiğinizde kamera + mikrofon izni istenir.
        İzni vermeden sınava başlayamazsınız.
    </div>

    <div class="card mb-3">
        <div class="card-body">

            <div class="d-flex align-items-start gap-4 flex-wrap">

                <!-- Video Preview -->
                <video id="previewVideo"
                       width="320"
                       height="240"
                       class="border rounded bg-dark"
                       autoplay
                       playsinline
                       muted></video>

                <!-- Control Panel -->
                <div class="d-flex flex-column gap-2">

                    <button class="btn btn-outline-primary"
                            @onclick="RequestPermission"
                            disabled="@_requesting">
                        @(_granted ? "Kamera/Mikrofon Açık (Tekrar Dene)" : "Kamera/Mikrofon İzni Tekrar İste")
                    </button>

                    <div>
                        Durum:
                        <span id="statusText"
                              class="badge @( _granted ? "bg-success" : "bg-secondary")">
                            @_statusText
                        </span>
                    </div>

                    <small class="text-muted">
                        Tarayıcı izin penceresi görünmezse butona tekrar basabilir veya sayfayı yenileyebilirsiniz.
                    </small>

                </div>
            </div>

        </div>
    </div>

    <button class="btn btn-primary"
            @onclick="StartExam"
            disabled="@(!_granted || _starting)">
        @(_starting ? "Başlatılıyor..." : "Sınava Başla")
    </button>
}

@code {
    [Parameter] public string Token { get; set; } = default!;

    private string? _error;
    private bool _granted;
    private bool _requesting;
    private bool _starting;
    private bool _permissionRequestedOnce;
    private string _statusText = "Bekleniyor";

    // Sayfa ilk render olduğunda otomatik izin iste
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_permissionRequestedOnce)
        {
            _permissionRequestedOnce = true;
            await RequestPermission();
        }
    }

    private async Task RequestPermission()
    {
        if (_requesting) return;

        _requesting = true;
        _statusText = "İzin isteniyor...";
        StateHasChanged();

        try
        {
            // JS: mediaGate.request(videoElementId, statusElementId)
            var ok = await JS.InvokeAsync<bool>(
                "mediaGate.request",
                "previewVideo",
                "statusText"
            );

            _granted = ok;
            _statusText = ok ? "İzin verildi, kamera açık." : "İzin alınamadı!";
        }
        catch
        {
            _granted = false;
            _statusText = "JS hatası, konsolu kontrol edin.";
        }

        _requesting = false;
        StateHasChanged();
    }

    private async Task StartExam()
    {
        // Güvenlik için ekstra kontrol: izin yoksa hiçbir şey yapma
        if (!_granted) return;

        try
        {
            _starting = true;
            StateHasChanged();

            var res = await ExamSessionApp.StartByTokenAsync(Token);
            Nav.NavigateTo($"/exam/runner/{res.Id}");
        }
        catch (Exception ex)
        {
            _error = "Geçersiz veya süresi dolmuş sınav bağlantısı! " + ex.Message;
            _starting = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("mediaGate.stop", "previewVideo", "statusText");
        }
        catch
        {
            // önemli değil
        }
    }
}
