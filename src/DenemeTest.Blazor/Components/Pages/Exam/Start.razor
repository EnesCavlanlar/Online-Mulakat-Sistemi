@page "/exam/start/{Token}"
@layout Shared.ExamLayout

@using System.Threading
@inject DenemeTest.Application.Exams.IExamSessionAppService ExamSessionApp
@inject NavigationManager Nav
@inject IJSRuntime JS

@implements IAsyncDisposable

<h3>Sınav Girişi</h3>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>

    <button class="btn btn-secondary mt-2" @onclick="ClearError">
        Tekrar Dene
    </button>
}
else
{
    <ol class="mb-3">
        <li>Kamera ve mikrofona izin ver.</li>
        <li><strong>Tüm ekran</strong> paylaşım izni ver.</li>
        <li>Her iki izin aktif olunca <b>Sınava Başla</b> butonu açılır.</li>
    </ol>

    <div class="alert alert-info">
        Sınav başladıktan sonra sekme değiştirme, pencere değiştirme, ekran paylaşımını kapatma veya sayfayı yenileme sınavı iptal eder.
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Kamera Önizleme</div>
                <div class="card-body">
                    <video id="camPreview"
                           class="border rounded w-100"
                           autoplay
                           playsinline
                           muted
                           style="height:240px">
                    </video>

                    <div class="d-flex align-items-center gap-2 mt-2">
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="RequestCam"
                                disabled="@(_camOk || _requestingCam || _starting)">
                            @GetCamButtonText()
                        </button>

                        <span class="badge @(_camOk ? "bg-success" : "bg-secondary")">
                            @(_camOk ? "Hazır" : "Bekleniyor")
                        </span>
                    </div>

                    <small class="text-muted d-block mt-2">
                        Kamera ve mikrofon izni tarayıcı tarafından istenir.
                    </small>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Ekran Paylaşımı Önizleme</div>
                <div class="card-body">
                    <video id="screenPreview"
                           class="border rounded w-100"
                           autoplay
                           playsinline
                           muted
                           style="height:240px">
                    </video>

                    <div class="d-flex align-items-center gap-2 mt-2">
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="RequestScreen"
                                disabled="@(_screenOk || _requestingScreen || _starting)">
                            @GetScreenButtonText()
                        </button>

                        <span class="badge @(_screenOk ? "bg-success" : "bg-secondary")">
                            @(_screenOk ? "Hazır" : "Bekleniyor")
                        </span>
                    </div>

                    <small class="text-muted d-block mt-2">
                        Mutlaka pencere/sekme değil, <strong>Tüm ekran</strong> seçmelisin.
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary"
                @onclick="StartExam"
                disabled="@(!(_camOk && _screenOk) || _starting)">
            @(_starting ? "Başlatılıyor..." : "Sınava Başla")
        </button>

        @if (_starting)
        {
            <div class="alert alert-info mt-3">
                Sınav oturumu hazırlanıyor. Kamera ve ekran kaydı başlatılıyor, lütfen bekle...
            </div>
        }
    </div>
}

@code
{
    [Parameter] public string Token { get; set; } = default!;

    private string? _error;

    private bool _camOk;
    private bool _screenOk;
    private bool _starting;
    private bool _requestingCam;
    private bool _requestingScreen;

    private bool _handoffToRunner;

    private async Task RequestCam()
    {
        _error = null;
        _requestingCam = true;

        try
        {
            var loaded = await IsMediaGateFunctionLoadedAsync("requestCam");
            if (!loaded)
            {
                _error = "Kamera modülü yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
                return;
            }

            _camOk = await JS.InvokeAsync<bool>("mediaGate.requestCam", "camPreview");

            if (!_camOk)
            {
                _error = "Kamera/mikrofon izni alınamadı.";
                return;
            }

            var active = await IsPreviewActiveAsync("camPreview");
            if (!active)
            {
                _camOk = false;
                _error = "Kamera/mikrofon izni alındı ancak önizleme aktif görünmüyor. Tekrar deneyin.";
            }
        }
        catch (Exception ex)
        {
            _camOk = false;
            _error = GetFriendlyJsError(ex, "Kamera/mikrofon izni alınamadı.");
        }
        finally
        {
            _requestingCam = false;
            StateHasChanged();
        }
    }

    private async Task RequestScreen()
    {
        _error = null;
        _requestingScreen = true;

        try
        {
            var loaded = await IsMediaGateFunctionLoadedAsync("requestScreen");
            if (!loaded)
            {
                _error = "Ekran paylaşımı modülü yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
                return;
            }

            _screenOk = await JS.InvokeAsync<bool>("mediaGate.requestScreen", "screenPreview");

            if (!_screenOk)
            {
                _error = "Ekran paylaşımı izni alınamadı.";
                return;
            }

            var active = await IsPreviewActiveAsync("screenPreview");
            var fullScreen = await IsFullScreenShareAsync("screenPreview");

            if (!active)
            {
                _screenOk = false;
                _error = "Ekran paylaşımı izni alındı ancak önizleme aktif görünmüyor. Tekrar deneyin.";
                return;
            }

            if (!fullScreen)
            {
                _screenOk = false;
                await StopPreviewSafelyAsync("screenPreview");
                _error = "Sınava başlamak için pencere veya sekme değil, Tüm ekran paylaşımı seçmelisin.";
            }
        }
        catch (Exception ex)
        {
            _screenOk = false;
            _error = GetFriendlyJsError(ex, "Ekran paylaşımı izni alınamadı.");
        }
        finally
        {
            _requestingScreen = false;
            StateHasChanged();
        }
    }

    private async Task StartExam()
    {
        if (!(_camOk && _screenOk) || _starting)
        {
            return;
        }

        _error = null;
        _starting = true;

        try
        {
            StateHasChanged();

            var mediaActive = await VerifyMediaStillActiveAsync();
            if (!mediaActive)
            {
                _starting = false;
                StateHasChanged();
                return;
            }

            var recorderLoaded = await IsRecorderFunctionLoadedAsync("start");
            if (!recorderLoaded)
            {
                _starting = false;
                _error = "Kayıt modülü yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
                StateHasChanged();
                return;
            }

            var result = await ExamSessionApp.StartByTokenAsync(Token);

            bool recorderStarted;

            try
            {
                recorderStarted = await InvokeWithTimeoutAsync(
                    () => JS.InvokeAsync<bool>("examRecorder.start", result.Id.ToString()).AsTask(),
                    TimeSpan.FromSeconds(10)
                );
            }
            catch (Exception ex)
            {
                await CancelStartedSessionSafelyAsync(result.Id, "Kamera/ekran kaydı başlatılamadı: " + ex.Message);

                _starting = false;
                _error = "Kamera/ekran kaydı başlatılırken zaman aşımı veya hata oluştu. Lütfen sayfayı kapatıp yeni davet linkiyle tekrar deneyin.";
                StateHasChanged();
                return;
            }

            if (!recorderStarted)
            {
                await CancelStartedSessionSafelyAsync(result.Id, "Kamera/ekran kaydı başlatılamadı.");

                _starting = false;
                _error = "Kamera/ekran kaydı başlatılamadı. Sınava devam edilemez. Lütfen kamera ve tüm ekran izinlerini tekrar verin.";
                StateHasChanged();
                return;
            }

            await Task.Delay(300);

            var recorderStatusOk = await IsRecorderStartedForSessionAsync(result.Id);
            if (!recorderStatusOk)
            {
                await CancelStartedSessionSafelyAsync(result.Id, "Kamera/ekran kaydı başladıktan sonra doğrulanamadı.");

                _starting = false;
                _error = "Kamera/ekran kaydı doğrulanamadı. Lütfen sayfayı kapatıp yeni davet linkiyle tekrar deneyin.";
                StateHasChanged();
                return;
            }

            await SaveActiveExamSessionToBrowserAsync(result.Id);

            _handoffToRunner = true;

            Nav.NavigateTo($"/exam/runner/{result.Id}", forceLoad: false);
        }
        catch (Exception ex)
        {
            _starting = false;
            _handoffToRunner = false;
            _error = GetFriendlyServerError(ex);
            StateHasChanged();
        }
    }

    private async Task CancelStartedSessionSafelyAsync(Guid sessionId, string reason)
    {
        try
        {
            if (sessionId != Guid.Empty)
            {
                await ExamSessionApp.CancelAsync(sessionId, reason);
            }
        }
        catch
        {
        }

        try
        {
            if (await IsRecorderFunctionLoadedAsync("cancel"))
            {
                await JS.InvokeVoidAsync("examRecorder.cancel");
            }
        }
        catch
        {
        }
    }

    private async Task<bool> IsRecorderStartedForSessionAsync(Guid sessionId)
    {
        try
        {
            var script =
                "(() => {" +
                " if (!window.examRecorder || typeof window.examRecorder.getStatus !== 'function') return false;" +
                " const s = window.examRecorder.getStatus();" +
                $" return !!(s && s.started === true && String(s.sessionId).toLowerCase() === '{sessionId.ToString().ToLowerInvariant()}');" +
                "})()";

            return await JS.InvokeAsync<bool>("eval", script);
        }
        catch
        {
            return false;
        }
    }

    private async Task SaveActiveExamSessionToBrowserAsync(Guid sessionId)
    {
        try
        {
            var script =
                $"sessionStorage.setItem('activeExamSessionId', '{sessionId}');" +
                $"sessionStorage.setItem('activeExamRecorderStarted', 'true');";

            await JS.InvokeVoidAsync("eval", script);
        }
        catch
        {
        }
    }

    private async Task<bool> VerifyMediaStillActiveAsync()
    {
        var mediaGateLoaded = await IsMediaGateLoadedAsync();
        if (!mediaGateLoaded)
        {
            _error = "Sınav medya modülü yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
            _camOk = false;
            _screenOk = false;
            return false;
        }

        var camActive = await IsPreviewActiveAsync("camPreview");
        var screenActive = await IsPreviewActiveAsync("screenPreview");
        var screenFull = await IsFullScreenShareAsync("screenPreview");

        if (!camActive)
        {
            _camOk = false;
        }

        if (!screenActive || !screenFull)
        {
            _screenOk = false;
        }

        if (!camActive)
        {
            _error = "Kamera/mikrofon aktif değil. Lütfen tekrar izin verin.";
            return false;
        }

        if (!screenActive)
        {
            _error = "Ekran paylaşımı aktif değil. Lütfen tekrar izin verin.";
            return false;
        }

        if (!screenFull)
        {
            _error = "Sınava başlamak için pencere veya sekme değil, Tüm ekran paylaşımı seçmelisin.";
            return false;
        }

        return true;
    }

    private async Task<bool> IsPreviewActiveAsync(string videoElementId)
    {
        try
        {
            var script =
                $"(() => {{" +
                $"const el = document.getElementById('{videoElementId}');" +
                $"const stream = el && el.srcObject;" +
                $"if (!stream || !stream.getTracks) return false;" +
                $"return stream.getTracks().some(t => t.readyState === 'live');" +
                $"}})()";

            return await JS.InvokeAsync<bool>("eval", script);
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> IsFullScreenShareAsync(string videoElementId)
    {
        try
        {
            var loaded = await IsMediaGateFunctionLoadedAsync("isFullScreenShare");
            if (!loaded)
            {
                return false;
            }

            return await JS.InvokeAsync<bool>("mediaGate.isFullScreenShare", videoElementId);
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> IsMediaGateLoadedAsync()
    {
        try
        {
            return await JS.InvokeAsync<bool>(
                "eval",
                "typeof window.mediaGate !== 'undefined'"
            );
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> IsMediaGateFunctionLoadedAsync(string functionName)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(functionName))
            {
                return await IsMediaGateLoadedAsync();
            }

            var script =
                $"typeof window.mediaGate !== 'undefined' && typeof window.mediaGate.{functionName} === 'function'";

            return await JS.InvokeAsync<bool>("eval", script);
        }
        catch
        {
            return false;
        }
    }

    private async Task<bool> IsRecorderFunctionLoadedAsync(string functionName)
    {
        try
        {
            var script =
                $"typeof window.examRecorder !== 'undefined' && typeof window.examRecorder.{functionName} === 'function'";

            return await JS.InvokeAsync<bool>("eval", script);
        }
        catch
        {
            return false;
        }
    }

    private static async Task<T> InvokeWithTimeoutAsync<T>(
        Func<Task<T>> action,
        TimeSpan timeout)
    {
        using var cts = new CancellationTokenSource();

        var task = action();
        var delayTask = Task.Delay(timeout, cts.Token);

        var completedTask = await Task.WhenAny(task, delayTask);

        if (completedTask == delayTask)
        {
            throw new TimeoutException("İşlem zaman aşımına uğradı.");
        }

        cts.Cancel();

        return await task;
    }

    private async Task StopPreviewSafelyAsync()
    {
        if (_handoffToRunner)
        {
            return;
        }

        try
        {
            var mediaGateLoaded = await IsMediaGateLoadedAsync();
            if (!mediaGateLoaded)
            {
                return;
            }

            await JS.InvokeVoidAsync("mediaGate.stopPreview", "camPreview");
            await JS.InvokeVoidAsync("mediaGate.stopPreview", "screenPreview");
        }
        catch
        {
        }
    }

    private async Task StopPreviewSafelyAsync(string videoElementId)
    {
        try
        {
            var mediaGateLoaded = await IsMediaGateLoadedAsync();
            if (!mediaGateLoaded)
            {
                return;
            }

            await JS.InvokeVoidAsync("mediaGate.stopPreview", videoElementId);
        }
        catch
        {
        }
    }

    private void ClearError()
    {
        _error = null;
        StateHasChanged();
    }

    private string GetCamButtonText()
    {
        if (_requestingCam)
        {
            return "İzin bekleniyor...";
        }

        return _camOk ? "Kamera/Mikrofon Açık" : "Kamera/Mikrofon İzni Ver";
    }

    private string GetScreenButtonText()
    {
        if (_requestingScreen)
        {
            return "İzin bekleniyor...";
        }

        return _screenOk ? "Ekran Paylaşımı Açık" : "Tüm Ekrana Erişim İzni Ver";
    }

    private static string GetFriendlyJsError(Exception ex, string fallback)
    {
        var message = ex.Message;

        if (message.Contains("Permission denied", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("NotAllowedError", StringComparison.OrdinalIgnoreCase))
        {
            return fallback + " Tarayıcı izni reddedildi.";
        }

        if (message.Contains("NotFoundError", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("Requested device not found", StringComparison.OrdinalIgnoreCase))
        {
            return fallback + " Kamera veya mikrofon cihazı bulunamadı.";
        }

        if (message.Contains("NotReadableError", StringComparison.OrdinalIgnoreCase))
        {
            return fallback + " Kamera/mikrofon başka bir uygulama tarafından kullanılıyor olabilir.";
        }

        if (message.Contains("Tüm ekran", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("monitor", StringComparison.OrdinalIgnoreCase))
        {
            return message;
        }

        if (message.Contains("mediaGate", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("undefined", StringComparison.OrdinalIgnoreCase))
        {
            return "Gerekli sınav medya modülü yüklenemedi. Sayfayı yenileyip tekrar deneyin.";
        }

        return $"{fallback} Detay: {message}";
    }

    private static string GetFriendlyServerError(Exception ex)
    {
        var message = ex.Message;

        if (message.Contains("zaten kullanılmış", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("AlreadyUsed", StringComparison.OrdinalIgnoreCase))
        {
            return "Bu sınav bağlantısı daha önce kullanılmış. Aynı link ile tekrar sınava girilemez.";
        }

        if (message.Contains("Davet bulunamadı", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("NotFound", StringComparison.OrdinalIgnoreCase))
        {
            return "Davet bağlantısı geçersiz.";
        }

        if (message.Contains("süresi geçmiş", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("Expired", StringComparison.OrdinalIgnoreCase))
        {
            return "Davet bağlantısının süresi geçmiş.";
        }

        if (message.Contains("Sınav henüz başlamadı", StringComparison.OrdinalIgnoreCase))
        {
            return "Sınav henüz başlamadı. Başlangıç zamanı gelmeden sınava giriş yapılamaz.";
        }

        if (message.Contains("bitiş zamanı geçmiş", StringComparison.OrdinalIgnoreCase) ||
            message.Contains("sona erdi", StringComparison.OrdinalIgnoreCase))
        {
            return "Sınavın bitiş zamanı geçmiş. Bu bağlantı ile artık sınava girilemez.";
        }

        if (message.Contains("aktif bir oturum var", StringComparison.OrdinalIgnoreCase))
        {
            return "Bu test için zaten aktif bir oturum var. Aynı davetle ikinci kez giriş yapılamaz.";
        }

        return message;
    }

    public async ValueTask DisposeAsync()
    {
        await StopPreviewSafelyAsync();
    }
}