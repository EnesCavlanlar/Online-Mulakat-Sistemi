@page "/exam/start/{Token}"
@layout Shared.ExamLayout

@inject DenemeTest.Application.Exams.IExamSessionAppService ExamSessionApp
@inject NavigationManager Nav
@inject IJSRuntime JS

@implements IAsyncDisposable

<h3>Sınav Girişi</h3>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else
{
    <ol class="mb-3">
        <li>Kamera ve mikrofona izin ver.</li>
        <li><strong>Tüm ekran</strong> paylaşım izni ver.</li>
        <li>Her iki izin aktif olunca <b>Sınava Başla</b> butonu açılır.</li>
    </ol>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Kamera Önizleme</div>
                <div class="card-body">
                    <video id="camPreview" class="border rounded w-100" autoplay playsinline muted style="height:240px"></video>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <button class="btn btn-outline-primary btn-sm" @onclick="RequestCam" disabled="@_camOk">
                            @(_camOk ? "Kamera/Mikrofon Açık" : "Kamera/Mikrofon izni Ver")
                        </button>
                        <span class="badge @( _camOk ? "bg-success" : "bg-secondary" )">@(_camOk ? "Hazır" : "Bekleniyor")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header">Ekran Paylaşımı Önizleme</div>
                <div class="card-body">
                    <video id="screenPreview" class="border rounded w-100" autoplay playsinline muted style="height:240px"></video>
                    <div class="d-flex align-items-center gap-2 mt-2">
                        <button class="btn btn-outline-primary btn-sm" @onclick="RequestScreen" disabled="@_screenOk">
                            @(_screenOk ? "Ekran Paylaşımı Açık" : "Tüm Ekrana Erişim izni Ver")
                        </button>
                        <span class="badge @( _screenOk ? "bg-success" : "bg-secondary" )">@(_screenOk ? "Hazır" : "Bekleniyor")</span>
                    </div>
                    <small class="text-muted d-block mt-2">
                        İpucu: “Tüm ekran”ı seçersen sekme değiştirilse bile kayıt devam eder.
                    </small>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="StartExam" disabled="@(!(_camOk && _screenOk) || _starting)">
            @(_starting ? "Başlatılıyor..." : "Sınava Başla")
        </button>
    </div>
}

@code
{
    [Parameter] public string Token { get; set; } = default!;

    private string? _error;
    private bool _camOk, _screenOk, _starting;

    private async Task RequestCam()
    {
        try { _camOk = await JS.InvokeAsync<bool>("mediaGate.requestCam", "camPreview"); }
        catch (Exception ex) { _error = ex.Message; }
        StateHasChanged();
    }

    private async Task RequestScreen()
    {
        try { _screenOk = await JS.InvokeAsync<bool>("mediaGate.requestScreen", "screenPreview"); }
        catch (Exception ex) { _error = ex.Message; }
        StateHasChanged();
    }

    private async Task StartExam()
    {
        if (!(_camOk && _screenOk)) return;
        try
        {
            _starting = true; StateHasChanged();

            await JS.InvokeVoidAsync("mediaGate.stopPreview", "camPreview");
            await JS.InvokeVoidAsync("mediaGate.stopPreview", "screenPreview");

            var res = await ExamSessionApp.StartByTokenAsync(Token);
            Nav.NavigateTo($"/exam/runner/{res.Id}");
        }
        catch (Exception ex) { _error = ex.Message; _starting = false; }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("mediaGate.stopPreview", "camPreview");
            await JS.InvokeVoidAsync("mediaGate.stopPreview", "screenPreview");
        }
        catch { }
    }
}
