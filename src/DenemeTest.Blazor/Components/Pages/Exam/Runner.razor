@page "/exam/runner/{SessionId:guid}"
@layout Shared.ExamLayout

@using DenemeTest.Exams
@using DenemeTest.Exams.Dtos
@using QT = DenemeTest.Exams.Dtos.QuestionTypeDto
@inject DenemeTest.Application.Exams.IExamSessionAppService SessionApp
@inject DenemeTest.Exams.IExamRunAppService RunApp
@inject DenemeTest.Exams.ICodeExecutionAppService CodeExecApp
@inject IJSRuntime JS
@inject NavigationManager Nav

@implements IAsyncDisposable

<h3 class="d-flex justify-content-between align-items-center">
    <span>@(_test?.TestName ?? "Sınav")</span>
    @if (_remainingSeconds > 0)
    {
        <span class="badge bg-info text-dark">
            Kalan süre: @_remainingMinutesDisplay dk @_remainingSecondsDisplay sn
        </span>
    }
</h3>

<div class="alert alert-warning">
    Sekme değiştirir, odak kaybedersen veya Alt+Tab yaparsan sınavın anında iptal edilir. Lütfen bu pencereden ayrılma.
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else if (_finished)
{
    <div class="alert alert-success">
        @if (_finishedByTimeout)
        {
            <span>Süreniz dolduğu için sınav otomatik olarak tamamlandı.</span>
    
            <br />
        }
        else
        {
            <span>Sınavı başarıyla tamamladınız.</span>
    
            <br />
        }
        Puanın: <strong>@_finalScore</strong><br />
        Bu pencere birazdan kapanacaktır. Teşekkürler.
    </div>
}
else if (_test == null)
{
    <p>Yükleniyor...</p>
}
else if (CurrentQuestion == null)
{
    <p>Bu oturuma ait soru bulunamadı.</p>
}
else
{
    <div class="mb-3">
        Soru @(_currentIndex + 1) / @_test.Questions.Count
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@CurrentQuestion.Text</h5>

            @switch (CurrentQuestion.Type)
            {
                case QT.MultipleChoice:
                    <div class="mt-3">
                        @foreach (var opt in CurrentQuestion.Options)
                        {
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       checked="@IsOptionSelected(CurrentQuestion.Id, opt.Id)"
                                       @onchange="(ChangeEventArgs e) => ToggleOption(CurrentQuestion.Id, opt.Id, (bool)e.Value!)" />
                                <label class="form-check-label">@opt.Text</label>
                            </div>
                        }
                    </div>
                    break;

                case QT.Classic:
                    <div class="mt-3">
                        <textarea class="form-control"
                                  rows="6"
                                  value="@GetTextAnswer(CurrentQuestion.Id)"
                                  @onchange="(ChangeEventArgs e) => SetTextAnswer(CurrentQuestion.Id, e.Value?.ToString())"></textarea>
                    </div>
                    break;

                case QT.Coding:
                    <div class="mt-3">
                        <textarea class="form-control"
                                  rows="14"
                                  spellcheck="false"
                                  style="font-family: Consolas, 'Courier New', monospace;"
                                  value="@GetTextAnswer(CurrentQuestion.Id)"
                                  @onchange="(ChangeEventArgs e) => SetTextAnswer(CurrentQuestion.Id, e.Value?.ToString())"></textarea>

                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@_runningCode"
                                    @onclick="RunCurrentCode">
                                @(_runningCode ? "Çalıştırılıyor..." : "Kodu Çalıştır")
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_runOutput))
                        {
                            <div class="mt-2">
                                <label class="form-label mb-1">Çıktı</label>
                                <pre class="bg-light p-2 rounded small">@_runOutput</pre>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_runError))
                        {
                            <div class="mt-2">
                                <label class="form-label mb-1 text-danger">Hata</label>
                                <pre class="bg-light p-2 rounded small text-danger">@_runError</pre>
                            </div>
                        }
                    </div>
                    break;
            }
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <div>
            <button class="btn btn-outline-secondary me-2"
                    disabled="@(_currentIndex == 0 || _saving)"
                    @onclick="PrevQuestion">
                Önceki
            </button>

            <button class="btn btn-outline-secondary"
                    disabled="@(_test == null || _currentIndex >= _test.Questions.Count - 1 || _saving)"
                    @onclick="NextQuestion">
                Sonraki
            </button>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-danger"
                    disabled="@_saving"
                    @onclick="CancelExam">
                Sınavı İptal Et
            </button>

            <button class="btn btn-primary"
                    disabled="@_saving"
                    @onclick="FinishExam">
                Sınavı Bitir
            </button>
        </div>
    </div>

    @if (_saving)
    {
        <p class="text-muted mt-2">Cevap kaydediliyor...</p>
    }
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private TestRunDto? _test;
    private int _currentIndex;
    private bool _saving;
    private bool _finished;
    private bool _finishedByTimeout;
    private bool _autoCancelled;
    private int _finalScore;
    private string? _error;

    private readonly Dictionary<Guid, HashSet<Guid>> _selected = new();
    private readonly Dictionary<Guid, string?> _texts = new();

    private bool _runningCode;
    private string? _runOutput;
    private string? _runError;

    private DotNetObjectReference<object>? _dotNetRef;

    private int _remainingSeconds = 0;
    private System.Timers.Timer? _timer;

    private int _remainingMinutesDisplay => _remainingSeconds / 60;
    private int _remainingSecondsDisplay => _remainingSeconds % 60;

    private QuestionRunDto? CurrentQuestion =>
        _test?.Questions != null && _currentIndex >= 0 && _currentIndex < _test.Questions.Count
            ? _test.Questions[_currentIndex]
            : null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _test = await RunApp.GetTestForRunAsync(SessionId);

            if (_test?.Questions != null && _test.Questions.Count > 0)
            {
                _currentIndex = 0;
                foreach (var q in _test.Questions)
                {
                    _selected[q.Id] = new HashSet<Guid>();
                    _texts[q.Id] = q.Type == QT.Coding ? GetDefaultCodeTemplate() : null;
                }
            }

            if (_test != null && _test.DurationMinutes > 0)
            {
                _remainingSeconds = _test.DurationMinutes * 60;
                StartTimer();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _test == null) return;

        _dotNetRef ??= DotNetObjectReference.Create<object>(this);

        await JS.InvokeVoidAsync("examProctor.init", _dotNetRef, SessionId.ToString());
        await JS.InvokeVoidAsync("examRecorder.start", SessionId.ToString());
    }

    private bool IsOptionSelected(Guid questionId, Guid optionId)
        => _selected.TryGetValue(questionId, out var set) && set.Contains(optionId);

    private void ToggleOption(Guid questionId, Guid optionId, bool selected)
    {
        if (!_selected.TryGetValue(questionId, out var set))
        {
            set = new HashSet<Guid>();
            _selected[questionId] = set;
        }
        if (selected) set.Add(optionId); else set.Remove(optionId);
    }

    private string GetTextAnswer(Guid questionId)
        => _texts.TryGetValue(questionId, out var t) ? t ?? string.Empty : string.Empty;

    private void SetTextAnswer(Guid questionId, string? text) => _texts[questionId] = text;

    private string GetDefaultCodeTemplate() =>
@"using System;

public class Program
{
    public static void Main()
    {
        // Kodunuzu buraya yazın.
    }
}";

    private async Task PrevQuestion()
    {
        await SaveCurrentAsync();
        if (_currentIndex > 0) { _currentIndex--; ResetRunState(); }
    }

    private async Task NextQuestion()
    {
        await SaveCurrentAsync();
        if (_test != null && _currentIndex < _test.Questions.Count - 1) { _currentIndex++; ResetRunState(); }
    }

    private void ResetRunState() { _runOutput = null; _runError = null; }

    private async Task RunCurrentCode()
    {
        if (_test == null || CurrentQuestion == null || CurrentQuestion.Type != QT.Coding) return;

        _runningCode = true; _runOutput = null; _runError = null; StateHasChanged();
        try
        {
            var req = new RunCodeRequestDto
            {
                SessionId = SessionId,
                QuestionId = CurrentQuestion.Id,
                Code = GetTextAnswer(CurrentQuestion.Id),
                Language = "csharp"
            };
            var res = await CodeExecApp.RunAsync(req);
            _runOutput = res.Output; _runError = res.Error;
        }
        catch (Exception ex) { _runError = ex.Message; }
        finally { _runningCode = false; StateHasChanged(); }
    }

    private async Task SaveCurrentAsync()
    {
        if (_test == null || CurrentQuestion == null) return;

        _saving = true; StateHasChanged();
        try
        {
            var q = CurrentQuestion;
            Guid[]? selectedIds = null; string? textAnswer = null;

            if (q.Type == QT.MultipleChoice) selectedIds = _selected[q.Id].ToArray();
            else if (q.Type is QT.Classic or QT.Coding) textAnswer = GetTextAnswer(q.Id);

            await RunApp.SubmitAnswerAsync(new SubmitAnswerDto
            {
                SessionId = SessionId,
                QuestionId = q.Id,
                SelectedOptionIds = selectedIds,
                TextAnswer = textAnswer
            });
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; StateHasChanged(); }
    }

    private Task FinishExam() => FinishExamInternal(false);

    private async Task FinishExamInternal(bool auto)
    {
        if (_finished || _test == null || _autoCancelled) return;

        try
        {
            _timer?.Stop();
            _remainingSeconds = 0;

            await SaveCurrentAsync();

            var score = await RunApp.ComputeAndSaveScoreAsync(SessionId);
            _finalScore = score;

            _finishedByTimeout = auto;
            var note = auto ? "Süre dolduğu için otomatik tamamlandı." : "Runner'dan kullanıcı tarafından tamamlandı.";

            await SessionApp.FinishAsync(SessionId, score, note);
            _finished = true;

            await JS.InvokeVoidAsync("examRecorder.stop", SessionId.ToString());
            await JS.InvokeVoidAsync("examRunner.closeWindow");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private Task CancelExam() => CancelInternal("Kullanıcı iptal etti.");

    private async Task CancelInternal(string reason)
    {
        try
        {
            _autoCancelled = true;
            _timer?.Stop();
            _remainingSeconds = 0;

            await JS.InvokeVoidAsync("examRecorder.cancel", SessionId.ToString());
            await SessionApp.CancelAsync(SessionId, reason);
            await JS.InvokeVoidAsync("examRunner.closeWindow");
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("examRecorder.stop", SessionId.ToString());
            await JS.InvokeVoidAsync("examProctor.dispose");
        }
        catch { }

        _timer?.Dispose();
        _dotNetRef?.Dispose();
    }

    // JS -> .NET: Politika ihlali olduğunda direkt iptal
    [JSInvokable]
    public async Task CancelByPolicy(string? reason)
    {
        if (_finished || _autoCancelled) return;
        await InvokeAsync(() => CancelInternal("Politika ihlali: " + (reason ?? "-")));
    }

    private void StartTimer()
    {
        if (_remainingSeconds <= 0) return;

        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += (_, __) =>
        {
            if (_finished || _autoCancelled) { _timer?.Stop(); return; }

            if (_remainingSeconds <= 0)
            {
                _timer?.Stop();
                _ = InvokeAsync(() => FinishExamInternal(true));
            }
            else
            {
                _remainingSeconds--;
                _ = InvokeAsync(StateHasChanged);
            }
        };
        _timer.AutoReset = true;
        _timer.Start();
    }
}
