@page "/exam/runner/{SessionId:guid}"
@layout Shared.ExamLayout

@using DenemeTest.Exams
@using DenemeTest.Exams.Dtos
@using QT = DenemeTest.Exams.Dtos.QuestionTypeDto
@using Microsoft.JSInterop
@using Microsoft.Extensions.Configuration

@inject DenemeTest.Application.Exams.IExamSessionAppService SessionApp
@inject DenemeTest.Exams.IExamRunAppService RunApp
@inject DenemeTest.Exams.ICodeExecutionAppService CodeExecApp
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config

@implements IAsyncDisposable

<h3>@(_test?.TestName ?? "Sınav")</h3>

<div class="alert alert-warning">
    Sekme değiştirir veya odak kaybı yaşarsan sınavın iptal edilebilir. Lütfen bu pencereden ayrılma.
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">@_error</div>
}
else if (_finished)
{
    <div class="alert alert-success">
        Sınav tamamlandı. Puanın: <strong>@_finalScore</strong>
    </div>

    <button class="btn btn-secondary" @onclick="GoHome">Kapat</button>
}
else if (_test == null)
{
    <p>Yükleniyor...</p>
}
else if (CurrentQuestion == null)
{
    <p>Bu oturuma ait soru bulunamadı.</p>
}
else
{
    <div class="mb-3">
        Soru @(_currentIndex + 1) / @_test.Questions.Count
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@CurrentQuestion.Text</h5>

            @switch (CurrentQuestion.Type)
            {
                case QT.MultipleChoice:
                    <div class="mt-3">
                        @foreach (var opt in CurrentQuestion.Options)
                        {
                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       checked="@IsOptionSelected(CurrentQuestion.Id, opt.Id)"
                                       @onchange="(ChangeEventArgs e) => ToggleOption(CurrentQuestion.Id, opt.Id, (bool)e.Value!)" />
                                <label class="form-check-label">@opt.Text</label>
                            </div>
                        }
                    </div>
                    break;

                case QT.Classic:
                    <div class="mt-3">
                        <textarea class="form-control"
                                  rows="6"
                                  value="@GetTextAnswer(CurrentQuestion.Id)"
                                  @onchange="(ChangeEventArgs e) => SetTextAnswer(CurrentQuestion.Id, e.Value?.ToString())">
                                    </textarea>
                    </div>
                    break;

                case QT.Coding:
                    <div class="mt-3">
                        <textarea class="form-control"
                                  rows="14"
                                  spellcheck="false"
                                  value="@GetTextAnswer(CurrentQuestion.Id)"
                                  @onchange="(ChangeEventArgs e) => SetTextAnswer(CurrentQuestion.Id, e.Value?.ToString())">
                                    </textarea>

                        <div class="mt-2 d-flex gap-2">
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@_runningCode"
                                    @onclick="RunCurrentCode">
                                @(_runningCode ? "Çalıştırılıyor..." : "Kodu Çalıştır")
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_runOutput))
                        {
                            <div class="mt-2">
                                <label class="form-label mb-1">Çıktı</label>
                                <pre class="bg-light p-2 rounded small">@_runOutput</pre>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_runError))
                        {
                            <div class="mt-2">
                                <label class="form-label mb-1 text-danger">Hata</label>
                                <pre class="bg-light p-2 rounded small text-danger">@_runError</pre>
                            </div>
                        }
                    </div>
                    break;
            }
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <div>
            <button class="btn btn-outline-secondary me-2"
                    disabled="@(_currentIndex == 0 || _saving)"
                    @onclick="PrevQuestion">
                Önceki
            </button>

            <button class="btn btn-outline-secondary"
                    disabled="@(_test == null || _currentIndex >= _test.Questions.Count - 1 || _saving)"
                    @onclick="NextQuestion">
                Sonraki
            </button>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-danger"
                    disabled="@_saving"
                    @onclick="CancelExam">
                Sınavı İptal Et
            </button>

            <button class="btn btn-primary"
                    disabled="@_saving"
                    @onclick="FinishExam">
                Sınavı Bitir
            </button>
        </div>
    </div>

    @if (_saving)
    {
        <p class="text-muted mt-2">Cevap kaydediliyor...</p>
    }
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private TestRunDto? _test;
    private int _currentIndex;
    private bool _saving;
    private bool _finished;
    private int _finalScore;
    private string? _error;

    // MCQ & text cevap state
    private readonly Dictionary<Guid, HashSet<Guid>> _selected = new();
    private readonly Dictionary<Guid, string?> _texts = new();

    // Coding run state
    private bool _runningCode;
    private string? _runOutput;
    private string? _runError;

    private QuestionRunDto? CurrentQuestion =>
        _test?.Questions != null && _currentIndex >= 0 && _currentIndex < _test.Questions.Count
            ? _test.Questions[_currentIndex]
            : null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _test = await RunApp.GetTestForRunAsync(SessionId);

            if (_test?.Questions != null && _test.Questions.Count > 0)
            {
                _currentIndex = 0;

                foreach (var q in _test.Questions)
                {
                    _selected[q.Id] = new HashSet<Guid>();

                    if (q.Type == QT.Coding)
                    {
                        // Coding sorular için temel kod iskeleti
                        _texts[q.Id] = GetDefaultCodeTemplate();
                    }
                    else
                    {
                        _texts[q.Id] = null;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _test == null)
            return;

        await SafeInvokeVoidAsync("examProctor.init", SessionId.ToString());
        await SafeInvokeVoidAsync("examRecorder.start", SessionId.ToString(), 2000, true);
    }

    private async Task SafeInvokeVoidAsync(string identifier, params object[] args)
    {
        try
        {
            await JS.InvokeVoidAsync(identifier, args);
        }
        catch
        {
            // JS tarafı yoksa sessiz geç
        }
    }

    // ---------- cevap state helpers ----------

    private bool IsOptionSelected(Guid questionId, Guid optionId)
        => _selected.TryGetValue(questionId, out var set) && set.Contains(optionId);

    private void ToggleOption(Guid questionId, Guid optionId, bool selected)
    {
        if (!_selected.TryGetValue(questionId, out var set))
        {
            set = new HashSet<Guid>();
            _selected[questionId] = set;
        }

        if (selected)
            set.Add(optionId);
        else
            set.Remove(optionId);
    }

    private string GetTextAnswer(Guid questionId)
        => _texts.TryGetValue(questionId, out var t) ? t ?? string.Empty : string.Empty;

    private void SetTextAnswer(Guid questionId, string? text)
    {
        _texts[questionId] = text;
    }

    // ---------- Varsayılan C# şablonu ----------

    private string GetDefaultCodeTemplate() =>
@"using System;

public class Program
{
    public static void Main()
    {
        // Kodunuzu buraya yazın.
    }
}";

    // ---------- Navigation ----------

    private async Task PrevQuestion()
    {
        await SaveCurrentAsync();
        if (_currentIndex > 0)
        {
            _currentIndex--;
            ResetRunState();
        }
    }

    private async Task NextQuestion()
    {
        await SaveCurrentAsync();
        if (_test != null && _currentIndex < _test.Questions.Count - 1)
        {
            _currentIndex++;
            ResetRunState();
        }
    }

    private void ResetRunState()
    {
        _runOutput = null;
        _runError = null;
    }

    // ---------- Coding: kod çalıştırma ----------

    private async Task RunCurrentCode()
    {
        if (_test == null || CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
            return;

        _runningCode = true;
        _runOutput = null;
        _runError = null;
        StateHasChanged();

        try
        {
            var code = GetTextAnswer(CurrentQuestion.Id);

            var req = new RunCodeRequestDto
            {
                SessionId = SessionId,
                QuestionId = CurrentQuestion.Id,
                Code = code,
                Language = "csharp"
            };

            var res = await CodeExecApp.RunAsync(req);

            _runOutput = res.Output;
            _runError = res.Error;
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
        }
        finally
        {
            _runningCode = false;
            StateHasChanged();
        }
    }

    // ---------- Cevap kaydetme & sınav bitirme ----------

    private async Task SaveCurrentAsync()
    {
        if (_test == null || CurrentQuestion == null)
            return;

        _saving = true;
        StateHasChanged();

        try
        {
            var q = CurrentQuestion;

            Guid[]? selectedIds = null;
            string? textAnswer = null;

            if (q.Type == QT.MultipleChoice)
            {
                selectedIds = _selected[q.Id].ToArray();
            }
            else if (q.Type == QT.Classic || q.Type == QT.Coding)
            {
                textAnswer = GetTextAnswer(q.Id);
            }

            var dto = new SubmitAnswerDto
            {
                SessionId = SessionId,
                QuestionId = q.Id,
                SelectedOptionIds = selectedIds,
                TextAnswer = textAnswer
            };

            await RunApp.SubmitAnswerAsync(dto);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task FinishExam()
    {
        if (_finished || _test == null)
            return;

        try
        {
            await SaveCurrentAsync();

            var score = await RunApp.ComputeAndSaveScoreAsync(SessionId);
            _finalScore = score;

            await SessionApp.FinishAsync(SessionId, score, "Runner'dan otomatik tamamlandı.");

            _finished = true;

            await SafeInvokeVoidAsync("examRecorder.stop", SessionId.ToString());
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task CancelExam()
    {
        try
        {
            await SessionApp.CancelAsync(SessionId, "Kullanıcı iptal etti.");
            await SafeInvokeVoidAsync("examRecorder.cancel", SessionId.ToString());
            GoHome();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await SafeInvokeVoidAsync("examRecorder.stop", SessionId.ToString());
            await SafeInvokeVoidAsync("examProctor.dispose", SessionId.ToString());
        }
        catch
        {
            // önemli değil
        }
    }

    // Proctoring tarafı JS'den çağırabilir
    [JSInvokable]
    public async Task ReportFocusLost(string? detail)
    {
        try
        {
            await SessionApp.RecordEventAsync(SessionId, ProctoringEventType.FocusLost, detail);
        }
        catch
        {
            // sessiz geç
        }
    }
}
