    {
        public string? SessionId { get; set; }

        public bool Started { get; set; }

        public bool Stopping { get; set; }

        public int CamChunks { get; set; }

        public int ScreenChunks { get; set; }

        public string? CamRecorderState { get; set; }

        public string? ScreenRecorderState { get; set; }
    }
