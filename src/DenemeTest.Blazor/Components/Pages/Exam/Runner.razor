@page "/exam/runner/{SessionId:guid}"
@layout Shared.ExamLayout

@using System.Threading
@using DenemeTest.Exams
@using DenemeTest.Exams.Dtos
@using QT = DenemeTest.Exams.Dtos.QuestionTypeDto
@inject DenemeTest.Application.Exams.IExamSessionAppService SessionApp
@inject DenemeTest.Exams.IExamRunAppService RunApp
@inject DenemeTest.Exams.ICodeExecutionAppService CodeExecApp
@inject IJSRuntime JS
@inject NavigationManager Nav

@implements IAsyncDisposable

<h3 class="d-flex justify-content-between align-items-center">
    <span>@(_test?.TestName ?? "Sınav")</span>

    @if (_remainingSeconds > 0)
    {
        <span class="badge bg-info text-dark">
            Kalan süre: @_remainingMinutesDisplay dk @_remainingSecondsDisplay sn
        </span>
    }
</h3>

<div class="alert alert-warning">
    Sekme değiştirir, odak kaybedersen, ekran paylaşımını kapatırsan veya Alt+Tab yaparsan sınavın iptal edilir. Lütfen bu pencereden ayrılma.
</div>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">
        @_error
    </div>

    @if (!_finished && !_autoCancelled)
    {
        <button class="btn btn-outline-primary mt-2"
                disabled="@_reloadingTest"
                @onclick="ReloadTestSafelyAsync">
            @(_reloadingTest ? "Sorular tekrar yükleniyor..." : "Soruları Tekrar Yükle")
        </button>
    }
}
else if (_finished)
{
    <div class="alert alert-success">
        @if (_finishedByTimeout)
        {
            <span>Süreniz dolduğu için sınav otomatik olarak tamamlandı.</span>
            <br />
        }
        else
        {
            <span>Sınavı başarıyla tamamladınız.</span>
            <br />
        }

        Puanın: <strong>@_finalScore</strong><br />
        Kayıtlar yüklendi. Bu pencere birazdan kapanacaktır. Teşekkürler.
    </div>
}
else if (_test == null)
{
    <p>Yükleniyor...</p>
}
else if (!_mediaReady)
{
    <div class="alert alert-info">
        Sınav güvenlik modülleri başlatılıyor. Kamera ve ekran kaydı hazırlanıyor, lütfen bekle...
    </div>

    <div class="spinner-border" role="status">
        <span class="visually-hidden">Yükleniyor...</span>
    </div>
}
else if (_test.Questions == null || !_test.Questions.Any())
{
    <div class="alert alert-danger">
        Bu sınav için soru bulunamadı. Sayfayı yenileme; aşağıdaki butonla soruları tekrar yüklemeyi dene.
    </div>

    <button class="btn btn-outline-primary"
            disabled="@_reloadingTest"
            @onclick="ReloadTestSafelyAsync">
        @(_reloadingTest ? "Sorular tekrar yükleniyor..." : "Soruları Tekrar Yükle")
    </button>
}
else if (CurrentQuestion == null)
{
    <div class="alert alert-warning">
        Mevcut soru hazırlanıyor. Lütfen birkaç saniye bekle.
    </div>

    <button class="btn btn-outline-primary"
            disabled="@_reloadingTest"
            @onclick="ReloadTestSafelyAsync">
        @(_reloadingTest ? "Sorular tekrar yükleniyor..." : "Soruları Tekrar Yükle")
    </button>
}
else
{
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <span>
            Soru @(_currentIndex + 1) / @_test.Questions.Count
        </span>

        <span class="badge bg-secondary">
            Soru tipi: @GetQuestionTypeText(CurrentQuestion.Type)
        </span>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">@CurrentQuestion.Text</h5>

            @switch (CurrentQuestion.Type)
            {
                case QT.MultipleChoice:
                    <div class="mt-3">
                        @if (CurrentQuestion.Options == null || !CurrentQuestion.Options.Any())
                        {
                            <div class="alert alert-warning">
                                Bu çoktan seçmeli soruya ait seçenek bulunamadı.
                            </div>
                        }
                        else
                        {
                            @foreach (var opt in CurrentQuestion.Options)
                            {
                                <div class="form-check" @key="opt.Id">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           checked="@IsOptionSelected(CurrentQuestion.Id, opt.Id)"
                                           @onchange="(ChangeEventArgs e) => ToggleOption(CurrentQuestion.Id, opt.Id, ConvertToBool(e.Value))" />

                                    <label class="form-check-label">@opt.Text</label>
                                </div>
                            }
                        }
                    </div>
                    break;

                case QT.Classic:
                    <div class="mt-3">
                        <textarea class="form-control"
                                  rows="6"
                                  value="@GetTextAnswer(CurrentQuestion.Id)"
                                  @onchange="(ChangeEventArgs e) => SetTextAnswer(CurrentQuestion.Id, e.Value?.ToString())">
                                    </textarea>
                    </div>
                    break;

                case QT.Coding:
                    <div class="mt-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label mb-0">C# Kod Editörü</label>
                            <span class="badge bg-dark">Monaco Editor</span>
                        </div>

                        <div id="@EditorElementId"
                             style="height:420px;border:1px solid #ddd;border-radius:8px;overflow:hidden;">
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_editorError))
                        {
                            <div class="alert alert-danger mt-2">
                                @_editorError
                            </div>
                        }

                        <div class="mt-3 d-flex gap-2 align-items-center">
                            <button class="btn btn-outline-secondary btn-sm"
                                    disabled="@_runningCode"
                                    @onclick="RunCurrentCode">
                                @if (_runningCode)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                    <span>Kod çalıştırılıyor, lütfen bekle...</span>
                                }
                                else
                                {
                                    <span>Kodu Çalıştır</span>
                                }
                            </button>

                            @if (_lastRunSuccess == true)
                            {
                                <span class="badge bg-success">Kod doğru</span>
                            }
                            else if (_lastRunSuccess == false)
                            {
                                <span class="badge bg-danger">Kod hatalı</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_runOutput))
                        {
                            <div class="mt-3">
                                <label class="form-label mb-1">Test Sonucu</label>
                                <pre class="bg-light p-3 rounded small border">@_runOutput</pre>
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(_runError))
                        {
                            <div class="mt-3">
                                <label class="form-label mb-1 text-danger">Hata</label>
                                <pre class="bg-light p-3 rounded small text-danger border border-danger">@_runError</pre>
                            </div>
                        }

                        @if (_runResult?.TestCases != null && _runResult.TestCases.Any())
                        {
                            <div class="mt-3">
                                <label class="form-label">Test Case Detayları</label>

                                <div class="row g-2">
                                    @{
                                        var testIndex = 0;
                                    }

                                    @foreach (var tc in _runResult.TestCases)
                                    {
                                        testIndex++;

                                        <div class="col-md-6" @key="testIndex">
                                            <div class="card h-100 @(tc.IsSuccess ? "border-success" : "border-danger")">
                                                <div class="card-body">
                                                    <h6 class="card-title">
                                                        Test @testIndex

                                                        @if (tc.IsSuccess)
                                                        {
                                                            <span class="badge bg-success ms-2">Geçti</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge bg-danger ms-2">Kaldı</span>
                                                        }
                                                    </h6>

                                                    @if (!string.IsNullOrWhiteSpace(tc.Input))
                                                    {
                                                        <div class="small mb-2">
                                                            <b>Input:</b>
                                                            <pre class="bg-light p-2 rounded mt-1 mb-0">@tc.Input</pre>
                                                        </div>
                                                    }

                                                    @if (tc.IsSuccess)
                                                    {
                                                        <div class="alert alert-success small mb-0">
                                                            Bu test başarıyla geçti.
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="alert alert-danger small mb-2">
                                                            Bu test başarısız oldu. Beklenen çıktı adaydan gizlenmiştir.
                                                        </div>

                                                        @if (!string.IsNullOrWhiteSpace(tc.ActualOutput))
                                                        {
                                                            <div class="small mb-2">
                                                                <b>Kodunun ürettiği çıktı:</b>
                                                                <pre class="bg-light p-2 rounded mt-1 mb-0">@tc.ActualOutput</pre>
                                                            </div>
                                                        }
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(tc.Error))
                                                    {
                                                        <div class="small text-danger">
                                                            <b>Hata:</b>
                                                            <pre class="bg-light p-2 rounded mt-1 mb-0 text-danger">@tc.Error</pre>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    break;
            }
        </div>
    </div>

    <div class="d-flex justify-content-between">
        <div>
            <button class="btn btn-outline-secondary me-2"
                    disabled="@(_currentIndex == 0 || _saving || _finalizingExam)"
                    @onclick="PrevQuestion">
                Önceki
            </button>

            <button class="btn btn-outline-secondary"
                    disabled="@(_test == null || _currentIndex >= _test.Questions.Count - 1 || _saving || _finalizingExam)"
                    @onclick="NextQuestion">
                Sonraki
            </button>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-danger"
                    disabled="@(_saving || _finalizingExam)"
                    @onclick="CancelExam">
                Sınavı İptal Et
            </button>

            <button class="btn btn-primary"
                    disabled="@(_saving || _finalizingExam)"
                    @onclick="FinishExam">
                @(_finalizingExam ? "Kayıtlar yükleniyor..." : "Sınavı Bitir")
            </button>
        </div>
    </div>

    @if (_saving)
    {
        <p class="text-muted mt-2">Cevap kaydediliyor...</p>
    }

    @if (_finalizingExam)
    {
        <div class="alert alert-info mt-3">
            Sınav tamamlanıyor. Kamera ve ekran kayıtları sunucuya yükleniyor, lütfen pencereyi kapatma.
        </div>
    }
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private TestRunDto? _test;
    private int _currentIndex;

    private bool _saving;
    private bool _finished;
    private bool _finishedByTimeout;
    private bool _autoCancelled;
    private bool _recorderFinalized;
    private bool _recorderStarted;
    private bool _mediaReady;
    private bool _securityInitStarted;
    private bool _finalizingExam;
    private bool _reloadingTest;

    private int _finalScore;
    private string? _error;

    private readonly Dictionary<Guid, HashSet<Guid>> _selected = new();
    private readonly Dictionary<Guid, string?> _texts = new();

    private bool _runningCode;
    private string? _runOutput;
    private string? _runError;
    private string? _editorError;
    private bool? _lastRunSuccess;
    private RunCodeResultDto? _runResult;

    private DotNetObjectReference<object>? _dotNetRef;

    private int _remainingSeconds = 0;
    private System.Timers.Timer? _timer;

    private bool _editorNeedsInit;
    private Guid? _lastInitializedEditorQuestionId;

    private int _remainingMinutesDisplay => _remainingSeconds / 60;
    private int _remainingSecondsDisplay => _remainingSeconds % 60;

    private QuestionRunDto? CurrentQuestion
    {
        get
        {
            if (_test?.Questions == null || _test.Questions.Count == 0)
            {
                return null;
            }

            if (_currentIndex < 0)
            {
                return _test.Questions[0];
            }

            if (_currentIndex >= _test.Questions.Count)
            {
                return _test.Questions[^1];
            }

            return _test.Questions[_currentIndex];
        }
    }

    private string EditorElementId =>
        CurrentQuestion == null
            ? "candidateCodeEditor"
            : $"candidateCodeEditor_{CurrentQuestion.Id:N}";

    protected override async Task OnInitializedAsync()
    {
        await LoadTestAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _test != null && string.IsNullOrWhiteSpace(_error))
        {
            await EnsureExamSecurityReadyAsync();
        }

        if (_mediaReady && !_finished && !_autoCancelled && CurrentQuestion?.Type == QT.Coding)
        {
            if (_editorNeedsInit || _lastInitializedEditorQuestionId != CurrentQuestion.Id)
            {
                await InitCodeEditorAsync();
            }
        }
    }

    private async Task LoadTestAsync()
    {
        try
        {
            _error = null;

            var loadedTest = await RunApp.GetTestForRunAsync(SessionId);

            _test = loadedTest;

            NormalizeCurrentIndex();
            EnsureAnswerContainers();

            if (_test != null && _test.DurationMinutes > 0 && _remainingSeconds <= 0)
            {
                _remainingSeconds = _test.DurationMinutes * 60;
            }

            if (CurrentQuestion?.Type == QT.Coding)
            {
                _editorNeedsInit = true;
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ReloadTestSafelyAsync()
    {
        if (_reloadingTest || _finalizingExam || _finished || _autoCancelled)
        {
            return;
        }

        _reloadingTest = true;

        try
        {
            await LoadTestAsync();

            if (_test?.Questions == null || !_test.Questions.Any())
            {
                _error = "Sorular tekrar yüklendi fakat bu teste ait soru bulunamadı. Admin panelinden bu teste soru ekli olduğundan emin ol.";
            }
            else
            {
                _error = null;
                NormalizeCurrentIndex();
                EnsureAnswerContainers();

                if (CurrentQuestion?.Type == QT.Coding)
                {
                    _editorNeedsInit = true;
                }
            }
        }
        catch (Exception ex)
        {
            _error = "Sorular tekrar yüklenemedi: " + ex.Message;
        }
        finally
        {
            _reloadingTest = false;
            StateHasChanged();
        }
    }

    private void NormalizeCurrentIndex()
    {
        if (_test?.Questions == null || _test.Questions.Count == 0)
        {
            _currentIndex = 0;
            return;
        }

        if (_currentIndex < 0)
        {
            _currentIndex = 0;
        }

        if (_currentIndex >= _test.Questions.Count)
        {
            _currentIndex = _test.Questions.Count - 1;
        }
    }

    private void EnsureAnswerContainers()
    {
        if (_test?.Questions == null)
        {
            return;
        }

        foreach (var q in _test.Questions)
        {
            if (!_selected.ContainsKey(q.Id))
            {
                _selected[q.Id] = new HashSet<Guid>();
            }

            if (!_texts.ContainsKey(q.Id))
            {
                _texts[q.Id] = q.Type == QT.Coding ? GetDefaultCodeTemplate() : null;
            }
        }
    }

    private async Task EnsureExamSecurityReadyAsync()
    {
        if (_securityInitStarted || _mediaReady)
        {
            return;
        }

        _securityInitStarted = true;

        try
        {
            RecorderStatusDto? recorderStatus = null;

            try
            {
                recorderStatus = await InvokeWithTimeoutAsync(
                    () => JS.InvokeAsync<RecorderStatusDto>("examRecorder.getStatus").AsTask(),
                    TimeSpan.FromSeconds(2)
                );
            }
            catch
            {
                recorderStatus = null;
            }

            if (recorderStatus == null ||
                !recorderStatus.Started ||
                !string.Equals(recorderStatus.SessionId, SessionId.ToString(), StringComparison.OrdinalIgnoreCase))
            {
                _error = "Kamera/ekran kaydı Start ekranında başlatılamamış görünüyor. Lütfen bu sınav penceresini kapatıp yeni davet linkiyle tekrar giriş yapın. Runner ekranında kayıt tekrar başlatılmaz.";
                StateHasChanged();
                return;
            }

            _recorderStarted = true;

            _dotNetRef ??= DotNetObjectReference.Create<object>(this);

            await JS.InvokeVoidAsync(
                "examProctor.init",
                _dotNetRef,
                SessionId.ToString()
            );

            _mediaReady = true;

            if (_test?.Questions == null || !_test.Questions.Any())
            {
                await LoadTestAsync();
            }

            NormalizeCurrentIndex();
            EnsureAnswerContainers();

            if (_remainingSeconds > 0)
            {
                StartTimer();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _error = "Sınav güvenlik modülleri başlatılamadı: " + ex.Message;
            StateHasChanged();
        }
    }

    private static async Task<T> InvokeWithTimeoutAsync<T>(
        Func<Task<T>> action,
        TimeSpan timeout)
    {
        using var cts = new CancellationTokenSource();

        var task = action();
        var delayTask = Task.Delay(timeout, cts.Token);

        var completedTask = await Task.WhenAny(task, delayTask);

        if (completedTask == delayTask)
        {
            throw new TimeoutException("İşlem zaman aşımına uğradı.");
        }

        cts.Cancel();

        return await task;
    }

    private async Task InitCodeEditorAsync()
    {
        if (CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
        {
            return;
        }

        try
        {
            _editorError = null;

            var code = GetTextAnswer(CurrentQuestion.Id);

            var ok = await JS.InvokeAsync<bool>(
                "codeEditor.init",
                EditorElementId,
                code
            );

            if (!ok)
            {
                _editorError = "Kod editörü başlatılamadı.";
                return;
            }

            _lastInitializedEditorQuestionId = CurrentQuestion.Id;
            _editorNeedsInit = false;

            await JS.InvokeVoidAsync("codeEditor.setDiagnostics", EditorElementId, null);
        }
        catch (Exception ex)
        {
            _editorError = "Kod editörü yüklenemedi: " + ex.Message;
            _editorNeedsInit = false;
        }

        StateHasChanged();
    }

    private async Task SyncEditorCodeToMemoryAsync()
    {
        if (CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
        {
            return;
        }

        try
        {
            var code = await JS.InvokeAsync<string>(
                "codeEditor.getValue",
                EditorElementId
            );

            _texts[CurrentQuestion.Id] = code;
        }
        catch
        {
        }
    }

    private async Task ClearEditorDiagnosticsAsync()
    {
        if (CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("codeEditor.setDiagnostics", EditorElementId, null);
        }
        catch
        {
        }
    }

    private async Task SetEditorDiagnosticsAsync(string? message)
    {
        if (CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("codeEditor.setDiagnostics", EditorElementId, message);
        }
        catch
        {
        }
    }

    private bool IsOptionSelected(Guid questionId, Guid optionId)
        => _selected.TryGetValue(questionId, out var set) && set.Contains(optionId);

    private void ToggleOption(Guid questionId, Guid optionId, bool selected)
    {
        if (!_selected.TryGetValue(questionId, out var set))
        {
            set = new HashSet<Guid>();
            _selected[questionId] = set;
        }

        if (selected)
        {
            set.Add(optionId);
        }
        else
        {
            set.Remove(optionId);
        }
    }

    private static bool ConvertToBool(object? value)
    {
        return value is bool b && b;
    }

    private string GetTextAnswer(Guid questionId)
        => _texts.TryGetValue(questionId, out var text) ? text ?? string.Empty : string.Empty;

    private void SetTextAnswer(Guid questionId, string? text)
    {
        _texts[questionId] = text;
    }

    private string GetDefaultCodeTemplate() =>
@"using System;

public class Program
{
    public static void Main()
    {
        // Kodunuzu buraya yazın.
    }
}";

    private async Task PrevQuestion()
    {
        await SaveCurrentAsync();

        if (_currentIndex > 0)
        {
            await DisposeCurrentEditorAsync();

            _currentIndex--;
            ResetRunState();

            if (CurrentQuestion?.Type == QT.Coding)
            {
                _editorNeedsInit = true;
            }
        }
    }

    private async Task NextQuestion()
    {
        await SaveCurrentAsync();

        if (_test != null && _currentIndex < _test.Questions.Count - 1)
        {
            await DisposeCurrentEditorAsync();

            _currentIndex++;
            ResetRunState();

            if (CurrentQuestion?.Type == QT.Coding)
            {
                _editorNeedsInit = true;
            }
        }
    }

    private async Task DisposeCurrentEditorAsync()
    {
        if (CurrentQuestion?.Type != QT.Coding)
        {
            return;
        }

        try
        {
            await SyncEditorCodeToMemoryAsync();
            await JS.InvokeVoidAsync("codeEditor.dispose", EditorElementId);
        }
        catch
        {
        }

        _lastInitializedEditorQuestionId = null;
    }

    private void ResetRunState()
    {
        _runOutput = null;
        _runError = null;
        _runResult = null;
        _lastRunSuccess = null;
        _editorError = null;
    }

    private async Task RunCurrentCode()
    {
        if (_test == null || CurrentQuestion == null || CurrentQuestion.Type != QT.Coding)
        {
            return;
        }

        _runningCode = true;
        _runOutput = null;
        _runError = null;
        _runResult = null;
        _lastRunSuccess = null;

        await ClearEditorDiagnosticsAsync();

        StateHasChanged();

        try
        {
            await SyncEditorCodeToMemoryAsync();

            var req = new RunCodeRequestDto
            {
                SessionId = SessionId,
                QuestionId = CurrentQuestion.Id,
                Code = GetTextAnswer(CurrentQuestion.Id),
                Language = "csharp"
            };

            var res = await CodeExecApp.RunAsync(req);

            _runResult = res;
            _runOutput = res.Output;
            _runError = res.Error;
            _lastRunSuccess = res.Success;

            if (!res.Success)
            {
                await SetEditorDiagnosticsAsync(res.Error);
            }
            else
            {
                await ClearEditorDiagnosticsAsync();
            }
        }
        catch (Exception ex)
        {
            _runError = ex.Message;
            _lastRunSuccess = false;
            await SetEditorDiagnosticsAsync(ex.Message);
        }
        finally
        {
            _runningCode = false;
            StateHasChanged();
        }
    }

    private async Task SaveCurrentAsync()
    {
        if (_test == null || CurrentQuestion == null)
        {
            return;
        }

        _saving = true;
        StateHasChanged();

        try
        {
            var question = CurrentQuestion;

            Guid[]? selectedIds = null;
            string? textAnswer = null;

            if (question.Type == QT.MultipleChoice)
            {
                selectedIds = _selected.TryGetValue(question.Id, out var set)
                    ? set.ToArray()
                    : Array.Empty<Guid>();
            }
            else if (question.Type == QT.Classic)
            {
                textAnswer = GetTextAnswer(question.Id);
            }
            else if (question.Type == QT.Coding)
            {
                await SyncEditorCodeToMemoryAsync();
                textAnswer = GetTextAnswer(question.Id);
            }

            await RunApp.SubmitAnswerAsync(new SubmitAnswerDto
            {
                SessionId = SessionId,
                QuestionId = question.Id,
                SelectedOptionIds = selectedIds,
                TextAnswer = textAnswer
            });
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private Task FinishExam() => FinishExamInternal(false);

    private async Task FinishExamInternal(bool auto)
    {
        if (_finished || _test == null || _autoCancelled || _finalizingExam)
        {
            return;
        }

        _finalizingExam = true;

        try
        {
            _timer?.Stop();
            _remainingSeconds = 0;

            await SaveCurrentAsync();

            var score = await RunApp.ComputeAndSaveScoreAsync(SessionId);
            _finalScore = score;

            _finishedByTimeout = auto;

            var note = auto
                ? "Süre dolduğu için otomatik tamamlandı."
                : "Runner'dan kullanıcı tarafından tamamlandı.";

            await SessionApp.FinishAsync(SessionId, score, note);

            var recordingOk = await StopRecorderSafelyAsync();

            if (!recordingOk)
            {
                _error = "Sınav tamamlandı ancak kamera/ekran kaydı sunucuya yüklenemedi. Lütfen bu ekranı kapatmadan önce geliştirici konsolundaki recorder loglarını kontrol et.";
                return;
            }

            _finished = true;

            StateHasChanged();

            await Task.Delay(1200);
            await JS.InvokeVoidAsync("examRunner.closeWindow");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _finalizingExam = false;
            StateHasChanged();
        }
    }

    private Task CancelExam() => CancelInternal("Kullanıcı iptal etti.");

    private async Task CancelInternal(string reason)
    {
        if (_finished || _autoCancelled || _finalizingExam)
        {
            return;
        }

        _autoCancelled = true;
        _finalizingExam = true;

        try
        {
            _timer?.Stop();
            _remainingSeconds = 0;

            await SaveCurrentAsync();

            int? scoreAtCancel = null;
            string cancelReason = reason;

            try
            {
                scoreAtCancel = await RunApp.ComputeAndSaveScoreAsync(SessionId);
                _finalScore = scoreAtCancel.Value;
                cancelReason = $"{reason} | İptal anındaki puan: {scoreAtCancel.Value}";
            }
            catch (Exception scoreEx)
            {
                cancelReason = $"{reason} | İptal anındaki puan hesaplanamadı: {scoreEx.Message}";
            }

            await SessionApp.CancelAsync(SessionId, cancelReason);

            var recordingOk = await StopRecorderSafelyAsync();

            if (!recordingOk)
            {
                _error = "Sınav iptal edildi ancak kamera/ekran kaydı sunucuya yüklenemedi. Lütfen bu ekranı kapatmadan önce geliştirici konsolundaki recorder loglarını kontrol et.";
                return;
            }

            StateHasChanged();

            await Task.Delay(1200);
            await JS.InvokeVoidAsync("examRunner.closeWindow");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _finalizingExam = false;
            StateHasChanged();
        }
    }

    private async Task<bool> StopRecorderSafelyAsync()
    {
        if (_recorderFinalized)
        {
            return true;
        }

        if (!_recorderStarted)
        {
            return false;
        }

        try
        {
            await JS.InvokeVoidAsync("examRecorder.stop");
            await Task.Delay(1500);

            var exists = await VerifyRecordingsUploadedAsync();

            if (!exists)
            {
                return false;
            }

            _recorderFinalized = true;
            _recorderStarted = false;

            return true;
        }
        catch (Exception ex)
        {
            Console.WriteLine("[Runner] recorder stop error: " + ex.Message);
            return false;
        }
    }

    private async Task<bool> VerifyRecordingsUploadedAsync()
    {
        try
        {
            var script =
                "fetch('/api/recordings/exists?sessionId=" + SessionId + "', { cache: 'no-store' })" +
                ".then(r => r.ok ? r.json() : null)" +
                ".then(j => !!(j && j.camExists === true && j.screenExists === true))" +
                ".catch(() => false)";

            return await JS.InvokeAsync<bool>("eval", script);
        }
        catch
        {
            return false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (CurrentQuestion?.Type == QT.Coding)
            {
                await JS.InvokeVoidAsync("codeEditor.dispose", EditorElementId);
            }

            if (_recorderStarted && !_recorderFinalized)
            {
                await StopRecorderSafelyAsync();
            }

            await JS.InvokeVoidAsync("examProctor.dispose");
        }
        catch
        {
        }

        _timer?.Dispose();
        _dotNetRef?.Dispose();
    }

    [JSInvokable]
    public async Task CancelByPolicy(string? reason)
    {
        if (_finished || _autoCancelled)
        {
            return;
        }

        var policyReason = string.IsNullOrWhiteSpace(reason) ? "-" : reason;

        try
        {
            await SessionApp.RecordEventAsync(
                SessionId,
                ProctoringEventTypeDto.FocusLost,
                policyReason
            );
        }
        catch
        {
        }

        await InvokeAsync(() => CancelInternal("Politika ihlali: " + policyReason));
    }

    private void StartTimer()
    {
        if (_remainingSeconds <= 0 || _timer != null)
        {
            return;
        }

        _timer = new System.Timers.Timer(1000);

        _timer.Elapsed += (_, __) =>
        {
            if (_finished || _autoCancelled)
            {
                _timer?.Stop();
                return;
            }

            if (_remainingSeconds <= 1)
            {
                _remainingSeconds = 0;
                _timer?.Stop();
                _ = InvokeAsync(() => FinishExamInternal(true));
            }
            else
            {
                _remainingSeconds--;
                _ = InvokeAsync(StateHasChanged);
            }
        };

        _timer.AutoReset = true;
        _timer.Start();
    }

    private static string GetQuestionTypeText(QT type)
    {
        return type switch
        {
            QT.MultipleChoice => "Çoktan Seçmeli",
            QT.Classic => "Klasik",
            QT.Coding => "Kodlama",
            _ => type.ToString()
        };
    }

