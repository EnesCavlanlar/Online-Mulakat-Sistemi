@page "/admin/questions"
@using DenemeTest.Exams
@using DenemeTest.Exams.Dtos
@inject DenemeTest.Application.Exams.IQuestionAppService QuestionApp
@inject DenemeTest.Application.Exams.ITestAppService TestApp
@inject DenemeTest.Exams.ICodeTestCaseAppService CodeTestCaseApp

@* DTO enum için kısa ad *@
@using QT = DenemeTest.Exams.Dtos.QuestionTypeDto

<h3>Sorular</h3>

@if (_loading)
{
    <p>Yükleniyor...</p>
}
else
{
    <div class="d-flex gap-2 mb-3">
        <button class="btn btn-primary" @onclick="NewQuestion">Yeni Soru</button>
        <select class="form-select w-auto" @onchange="OnTestFilterChanged">
            <option value="">(Tüm Testler)</option>
            @foreach (var t in _tests)
            {
                <option value="@t.Id" selected="@(_filterTestId == t.Id.ToString())">@t.Name</option>
            }
        </select>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Test</th>
                <th>Tür</th>
                <th>Metin</th>
                <th>Puan</th>
                <th>Seçenek</th>
                <th style="width:140px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var q in _items)
            {
                <tr>
                    <td>@_tests.FirstOrDefault(t => t.Id == q.TestId)?.Name</td>
                    <td>@q.Type</td>
                    <td>@q.Text</td>
                    <td>@q.Points</td>
                    <td>@(q.Options?.Count ?? 0)</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => EditAsync(q)">Düzenle</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(q.Id)">Sil</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_showModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId == null ? "Yeni Soru" : "Soru Düzenle")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Test</label>
                            <select class="form-select" @bind="_form.TestId">
                                @foreach (var t in _tests)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Tür</label>
                            <select class="form-select" @bind="_form.Type">
                                <option value="@QT.MultipleChoice">Çoktan Seçmeli</option>
                                <option value="@QT.Classic">Klasik</option>
                                <option value="@QT.Coding">Kodlama Sorusu</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label">Puan</label>
                            <input type="number" class="form-control" @bind="_form.Points" min="1" />
                        </div>

                        <div class="col-12">
                            <label class="form-label">Soru Metni</label>
                            <textarea class="form-control" rows="3" @bind="_form.Text"></textarea>
                        </div>

                        @* Çoktan seçmeli seçenek yönetimi *@
                        @if (_form.Type == QT.MultipleChoice)
                        {
                            <div class="col-12">
                                <label class="form-label d-block">Seçenekler</label>

                                @for (int i = 0; i < _form.Options.Count; i++)
                                {
                                    <div class="input-group mb-2">
                                        <span class="input-group-text">
                                            <input class="form-check-input mt-0" type="checkbox" @bind="_form.Options[i].IsCorrect" />
                                        </span>
                                        <input class="form-control"
                                               placeholder="Seçenek metni"
                                               @bind="_form.Options[i].Text" />
                                        <button class="btn btn-outline-danger"
                                                type="button"
                                                @onclick="(() => RemoveOption(i))">
                                            Sil
                                        </button>
                                    </div>
                                }
                                <button class="btn btn-sm btn-outline-primary" type="button" @onclick="AddOption">
                                    Seçenek Ekle
                                </button>
                            </div>
                        }

                        @* Kodlama soruları için test-case yönetimi *@
                        @if (_form.Type == QT.Coding)
                        {
                            <div class="col-12 mt-3">
                                <label class="form-label d-block">Kodlama Test Case'leri</label>

                                @if (_editId == null)
                                {
                                    <div class="alert alert-info">
                                        Test-case ekleyebilmek için önce soruyu kaydedin, sonra tekrar düzenleyerek açın.
                                    </div>
                                }
                                else
                                {
                                    @if (_loadingCodeCases)
                                    {
                                        <p>Test-case'ler yükleniyor...</p>
                                    }
                                    else
                                    {
                                        @if (_codeCases.Count == 0)
                                        {
                                            <p class="text-muted">Bu soru için henüz test-case tanımlanmamış.</p>
                                        }

                                        @foreach (var caseModel in _codeCases)
                                        {
                                            <div class="border rounded p-2 mb-2">
                                                <div class="mb-2">
                                                    <label class="form-label">Input</label>
                                                    <textarea class="form-control"
                                                              rows="2"
                                                              @bind="caseModel.Input"></textarea>
                                                </div>
                                                <div class="mb-2">
                                                    <label class="form-label">Beklenen Çıktı</label>
                                                    <textarea class="form-control"
                                                              rows="2"
                                                              @bind="caseModel.ExpectedOutput"></textarea>
                                                </div>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div>
                                                        <label class="form-label">Ağırlık</label>
                                                        <input type="number"
                                                               class="form-control"
                                                               style="max-width: 120px"
                                                               @bind="caseModel.Weight"
                                                               min="1" />
                                                    </div>
                                                    <button type="button"
                                                            class="btn btn-outline-danger ms-auto"
                                                            @onclick="(() => RemoveCodeCase(caseModel))">
                                                        Sil
                                                    </button>
                                                </div>
                                            </div>
                                        }

                                        <div class="d-flex flex-column gap-2">
                                            <div class="d-flex gap-2">
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary"
                                                        @onclick="AddCodeCase">
                                                    Test Case Ekle
                                                </button>
                                                <button type="button"
                                                        class="btn btn-sm btn-success"
                                                        @onclick="SaveCodeCasesAsync">
                                                    Test Case'leri Kaydet
                                                </button>
                                            </div>

                                            @* Kaydetme bildirimleri *@
                                            @if (!string.IsNullOrEmpty(_codeCasesInfo))
                                            {
                                                <span class="text-success small">@_codeCasesInfo</span>
                                            }
                                            @if (!string.IsNullOrEmpty(_codeCasesError))
                                            {
                                                <span class="text-danger small">@_codeCasesError</span>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Kapat</button>
                    <button class="btn btn-primary" @onclick="Save">Kaydet</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private List<QuestionDto> _items = new();
    private List<TestDto> _tests = new();
    private string? _filterTestId;

    private bool _showModal = false;
    private Guid? _editId;
    private CreateUpdateQuestionDto _form = new();

    // Coding test case state
    private List<CodeTestCaseDto> _codeCases = new();
    private bool _loadingCodeCases = false;

    // Test-case bildirimleri
    private string? _codeCasesInfo;
    private string? _codeCasesError;

    protected override async Task OnInitializedAsync()
    {
        await LoadTests();
        await LoadData();
    }

    private async Task LoadTests()
    {
        var list = await TestApp.GetListAsync(new Volo.Abp.Application.Dtos.PagedAndSortedResultRequestDto());
        _tests = list.Items.ToList();
    }

    private async Task LoadData()
    {
        _loading = true;

        var list = await QuestionApp.GetListAsync(new Volo.Abp.Application.Dtos.PagedAndSortedResultRequestDto());
        var all = list.Items.ToList();

        if (!string.IsNullOrWhiteSpace(_filterTestId) && Guid.TryParse(_filterTestId, out var tid))
            _items = all.Where(x => x.TestId == tid).ToList();
        else
            _items = all;

        _loading = false;
    }

    private async Task OnTestFilterChanged(ChangeEventArgs e)
    {
        _filterTestId = e.Value?.ToString();
        await LoadData();
    }

    private void NewQuestion()
    {
        _editId = null;
        _form = new CreateUpdateQuestionDto
        {
            Points = 1,
            Type = QT.MultipleChoice, // DTO enum
            Options = new List<CreateUpdateQuestionOptionDto>()
        };
        if (_tests.Count > 0) _form.TestId = _tests[0].Id;

        _codeCases = new List<CodeTestCaseDto>();
        _codeCasesInfo = null;
        _codeCasesError = null;

        _showModal = true;
    }

    private async Task EditAsync(QuestionDto dto)
    {
        _editId = dto.Id;
        _form = new CreateUpdateQuestionDto
        {
            TestId = dto.TestId,
            Type = dto.Type, // zaten DTO enum
            Text = dto.Text,
            Points = dto.Points,
            Options = dto.Options?.Select(o => new CreateUpdateQuestionOptionDto
            {
                Text = o.Text,
                IsCorrect = o.IsCorrect
            }).ToList()
                      ?? new List<CreateUpdateQuestionOptionDto>()
        };

        _codeCases = new List<CodeTestCaseDto>();
        _codeCasesInfo = null;
        _codeCasesError = null;

        _showModal = true;

        if (_form.Type == QT.Coding)
        {
            await LoadCodeCasesAsync(dto.Id);
            StateHasChanged();
        }
    }

    private async Task LoadCodeCasesAsync(Guid questionId)
    {
        _loadingCodeCases = true;
        _codeCases = await CodeTestCaseApp.GetListByQuestionAsync(questionId);
        _loadingCodeCases = false;
    }

    private async Task Delete(Guid id)
    {
        if (!await JsConfirm("Silmek istediğine emin misin?")) return;
        await QuestionApp.DeleteAsync(id);
        await LoadData();
        StateHasChanged();
    }

    private async Task Save()
    {
        if (_editId == null)
            await QuestionApp.CreateAsync(_form);
        else
            await QuestionApp.UpdateAsync(_editId.Value, _form);

        _showModal = false;
        _codeCases = new List<CodeTestCaseDto>();
        _codeCasesInfo = null;
        _codeCasesError = null;

        await LoadData();
        StateHasChanged();
    }

    private void CloseModal()
    {
        _showModal = false;
        _codeCases = new List<CodeTestCaseDto>();
        _codeCasesInfo = null;
        _codeCasesError = null;
    }

    private void AddOption()
        => _form.Options.Add(new CreateUpdateQuestionOptionDto { Text = "", IsCorrect = false });

    private void RemoveOption(int i)
    {
        if (i >= 0 && i < _form.Options.Count) _form.Options.RemoveAt(i);
    }

    private void AddCodeCase()
    {
        if (_editId == null) return;

        _codeCasesInfo = null;
        _codeCasesError = null;

        _codeCases.Add(new CodeTestCaseDto
        {
            QuestionId = _editId.Value,
            Input = string.Empty,
            ExpectedOutput = string.Empty,
            Weight = 1
        });
    }

    private void RemoveCodeCase(CodeTestCaseDto dto)
    {
        if (dto is not null && _codeCases.Contains(dto))
        {
            _codeCases.Remove(dto);
        }
    }

    private async Task SaveCodeCasesAsync()
    {
        _codeCasesInfo = null;
        _codeCasesError = null;

        if (_editId == null)
        {
            _codeCasesError = "Test-case kaydetmek için önce soruyu kaydetmelisin.";
            StateHasChanged();
            return;
        }

        try
        {
            await CodeTestCaseApp.ReplaceForQuestionAsync(_editId.Value, _codeCases);
            await LoadCodeCasesAsync(_editId.Value);
            _codeCasesInfo = "Test-case'ler başarıyla kaydedildi.";
        }
        catch (Exception ex)
        {
            _codeCasesError = "Test-case kaydedilirken hata oluştu: " + ex.Message;
        }

        StateHasChanged();
    }

    // basit confirm (şimdilik true döndürüyoruz)
    private async Task<bool> JsConfirm(string message)
    {
        await Task.CompletedTask;
        return true;
    }
}
