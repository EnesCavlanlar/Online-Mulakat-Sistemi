@page "/admin/reports"
@using System.Linq
@using DenemeTest.Exams.Dtos
@inject DenemeTest.Application.Exams.IReportsAppService ReportsApp
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Raporlar</h3>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

<div class="d-flex align-items-center gap-3 mb-3">
    <label class="form-label mb-0">Gösterim:</label>

    <select class="form-select w-auto" @bind="_take" @bind:event="onchange">
        <option value="10">İlk 10</option>
        <option value="20">İlk 20</option>
        <option value="30">İlk 30</option>
        <option value="50">İlk 50</option>
        <option value="100">İlk 100</option>
    </select>

    <button class="btn btn-outline-primary" @onclick="Reload">
        Yenile
    </button>
</div>

@if (_items == null)
{
    <p>Yükleniyor...</p>
}
else if (!_items.Any())
{
    <div class="alert alert-info">Henüz puanlanmış sınav bulunmuyor.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:60px">#</th>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th style="width:90px">Puan</th>
                <th style="width:140px">Durum</th>
                <th style="width:150px">Bitiş Zamanı</th>
                <th style="width:90px">İhlal</th>
                <th style="width:270px">İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @{
                var idx = 0;
            }

            @foreach (LeaderboardItemDto row in _items!)
            {
                var rowClass = GetRowCss(row);

                <tr class="@rowClass">
                    <td>@(++idx)</td>
                    <td>@row.FirstName @row.LastName</td>
                    <td>@row.Email</td>
                    <td><strong>@row.Score</strong></td>

                    <td>
                        @RenderStatus(row)
                    </td>

                    <td>
                        @if (row.FinishedAt.HasValue)
                        {
                            @row.FinishedAt.Value.ToLocalTime().ToString("g")
                        }
                        else
                        {
                            <span class="text-muted">–</span>
                        }
                    </td>

                    <td>
                        @if (row.ViolationCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@row.ViolationCount</span>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>

                    <td>
                        <button class="btn btn-sm btn-primary me-1"
                                @onclick="() => GoToDetail(row.ExamSessionId)">
                            Detay
                        </button>

                        <button class="btn btn-sm btn-outline-secondary me-1"
                                @onclick="() => DownloadRecording(row.ExamSessionId)">
                            Kayıt
                        </button>

                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => DeleteSession(row)">
                            Sil
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int _take = 30;
    private LeaderboardItemDto[]? _items;

    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task Reload()
    {
        _errorMessage = null;
        _successMessage = null;
        _items = null;

        try
        {
            _items = await ReportsApp.GetLeaderboardAsync(_take);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _items = Array.Empty<LeaderboardItemDto>();
        }

        StateHasChanged();
    }

    private void GoToDetail(Guid id)
    {
        Nav.NavigateTo($"/admin/session/{id}");
    }

    private void DownloadRecording(Guid sessionId)
    {
        var url = $"/api/recordings/download?sessionId={sessionId}";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task DeleteSession(LeaderboardItemDto row)
    {
        _errorMessage = null;
        _successMessage = null;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"{row.FirstName} {row.LastName} adlı adayın bu sınav kaydını silmek istediğine emin misin? Bu işlem cevapları, skoru ve proctoring kayıtlarını da siler."
        );

        if (!confirmed)
        {
            return;
        }

        try
        {
            await ReportsApp.DeleteSessionAsync(row.ExamSessionId);
            _successMessage = "Sınav kaydı silindi.";
            await Reload();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private string GetRowCss(LeaderboardItemDto row)
    {
        if (row.IsCancelled)
        {
            return "table-danger";
        }

        if (row.FinishedAt.HasValue)
        {
            return "table-success";
        }

        return string.Empty;
    }

    private RenderFragment RenderStatus(LeaderboardItemDto row) => builder =>
    {
        var status = row.IsCancelled
            ? "İptal"
            : row.FinishedAt.HasValue ? "Tamamlandı" : "Devam Ediyor";

        var css = row.IsCancelled
            ? "badge bg-danger"
            : row.FinishedAt.HasValue ? "badge bg-success" : "badge bg-secondary";

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", css);
        builder.AddContent(2, status);
        builder.CloseElement();
    };
}