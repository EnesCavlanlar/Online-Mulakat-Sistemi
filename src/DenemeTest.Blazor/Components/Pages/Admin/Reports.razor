@page "/admin/reports"
@using System.Linq
@using DenemeTest.Exams.Dtos
@inject DenemeTest.Application.Exams.IReportsAppService ReportsApp
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Raporlar</h3>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

@if (_items != null)
{
    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <div class="card border-primary h-100">
                <div class="card-body">
                    <div class="text-muted small">Toplam Oturum</div>
                    <h4 class="mb-0">@_items.Length</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-success h-100">
                <div class="card-body">
                    <div class="text-muted small">Tamamlanan</div>
                    <h4 class="mb-0">@_items.Count(x => !x.IsCancelled && x.FinishedAt.HasValue)</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-danger h-100">
                <div class="card-body">
                    <div class="text-muted small">İptal Edilen</div>
                    <h4 class="mb-0">@_items.Count(x => x.IsCancelled)</h4>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-secondary h-100">
                <div class="card-body">
                    <div class="text-muted small">Devam Eden</div>
                    <h4 class="mb-0">@_items.Count(x => !x.IsCancelled && !x.FinishedAt.HasValue)</h4>
                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
    <label class="form-label mb-0">Gösterim:</label>

    <select class="form-select w-auto" value="@_take" @onchange="OnTakeChanged">
        <option value="10">İlk 10</option>
        <option value="20">İlk 20</option>
        <option value="30">İlk 30</option>
        <option value="50">İlk 50</option>
        <option value="100">İlk 100</option>
    </select>

    <button class="btn btn-outline-primary" @onclick="Reload">
        Yenile
    </button>
</div>

@if (_items == null)
{
    <p>Yükleniyor...</p>
}
else if (!_items.Any())
{
    <div class="alert alert-info">
        Henüz sınav oturumu bulunmuyor.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th style="width:60px">#</th>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th style="width:100px">Puan</th>
                    <th style="width:140px">Durum</th>
                    <th style="width:170px">Bitiş Zamanı</th>
                    <th style="width:90px">İhlal</th>
                    <th style="width:360px">İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @{
                    var idx = 0;
                }

                @foreach (LeaderboardItemDto row in _items)
                {
                    var rowClass = GetRowCss(row);
                    var scoreCss = GetScoreBadgeCss(row.Score);
                    var cacheKey = DateTimeOffset.Now.ToUnixTimeSeconds();

                    var candidateVideoUrl = $"/api/recordings/download?sessionId={row.ExamSessionId}&kind=cam&v={cacheKey}";
                    var screenVideoUrl = $"/api/recordings/download?sessionId={row.ExamSessionId}&kind=screen&v={cacheKey}";

                    <tr class="@rowClass">
                        <td>@(++idx)</td>

                        <td>
                            <strong>@row.FirstName @row.LastName</strong>
                        </td>

                        <td>@row.Email</td>

                        <td>
                            <span class="@scoreCss">@row.Score/100</span>
                        </td>

                        <td>
                            <span class="@GetStatusBadgeCss(row)">
                                @GetStatusText(row)
                            </span>
                        </td>

                        <td>
                            @if (row.FinishedAt.HasValue)
                            {
                                @row.FinishedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>

                        <td>
                            @if (row.ViolationCount > 0)
                            {
                                <span class="badge bg-warning text-dark">@row.ViolationCount</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">0</span>
                            }
                        </td>

                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => GoToDetail(row.ExamSessionId)">
                                    Detay
                                </button>

                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@candidateVideoUrl"
                                   target="_blank">
                                    Kamera
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@screenVideoUrl"
                                   target="_blank">
                                    Ekran
                                </a>

                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeleteSession(row)">
                                    Sil
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private int _take = 30;
    private LeaderboardItemDto[]? _items;

    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        await Reload();
    }

    private async Task OnTakeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value))
        {
            _take = value;
        }

        await Reload();
    }

    private async Task Reload()
    {
        _errorMessage = null;
        _successMessage = null;
        _items = null;

        try
        {
            _items = await ReportsApp.GetLeaderboardAsync(_take);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _items = Array.Empty<LeaderboardItemDto>();
        }

        StateHasChanged();
    }

    private void GoToDetail(Guid id)
    {
        Nav.NavigateTo($"/admin/session/{id}");
    }

    private async Task DeleteSession(LeaderboardItemDto row)
    {
        _errorMessage = null;
        _successMessage = null;

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            $"{row.FirstName} {row.LastName} adlı adayın sınav kaydını silmek istediğine emin misin?\n\nBu işlem cevapları, skoru, LLM analizini ve proctoring event kayıtlarını siler.\n\nNot: Video dosyaları şu an diskten ayrıca silinmez."
        );

        if (!confirmed)
        {
            return;
        }

        try
        {
            await ReportsApp.DeleteSessionAsync(row.ExamSessionId);
            _successMessage = "Sınav kaydı silindi.";
            await Reload();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private static string GetRowCss(LeaderboardItemDto row)
    {
        if (row.IsCancelled)
        {
            return "table-danger";
        }

        if (row.FinishedAt.HasValue)
        {
            return "table-success";
        }

        return string.Empty;
    }

    private static string GetStatusText(LeaderboardItemDto row)
    {
        if (row.IsCancelled)
        {
            return "İptal";
        }

        if (row.FinishedAt.HasValue)
        {
            return "Tamamlandı";
        }

        return "Devam Ediyor";
    }

    private static string GetStatusBadgeCss(LeaderboardItemDto row)
    {
        if (row.IsCancelled)
        {
            return "badge bg-danger";
        }

        if (row.FinishedAt.HasValue)
        {
            return "badge bg-success";
        }

        return "badge bg-secondary";
    }

    private static string GetScoreBadgeCss(int score)
    {
        if (score >= 70)
        {
            return "badge bg-success";
        }

        if (score >= 40)
        {
            return "badge bg-warning text-dark";
        }

        return "badge bg-danger";
    }
}