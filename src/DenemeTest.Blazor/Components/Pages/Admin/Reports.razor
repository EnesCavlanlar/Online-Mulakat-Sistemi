@page "/admin/reports"
@using System.Linq
@using DenemeTest.Exams.Dtos
@inject DenemeTest.Application.Exams.IReportsAppService ReportsApp
@inject NavigationManager Nav

<h3>Raporlar</h3>

<div class="d-flex align-items-center gap-3 mb-3">
    <label class="form-label mb-0">Gösterim:</label>
    <select class="form-select w-auto" @bind="_take" @bind:event="onchange">
        <option value="10">İlk 10</option>
        <option value="20">İlk 20</option>
        <option value="30">İlk 30</option>
        <option value="50">İlk 50</option>
    </select>

    <button class="btn btn-outline-primary" @onclick="Reload">
        Yenile
    </button>
</div>

@if (_items == null)
{
    <p>Yükleniyor...</p>
}
else if (!_items.Any())
{
    <div class="alert alert-info">Henüz puanlanmış sınav bulunmuyor.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th style="width:60px">#</th>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th style="width:90px">Puan</th>
                <th style="width:140px">Durum</th>
                <th style="width:150px">Bitiş Zamanı</th>
                <th style="width:90px">İhlal</th>
                <th style="width:150px">Kayıt</th>
                <th style="width:120px">Detay</th>
            </tr>
        </thead>
        <tbody>
            @{
                var idx = 0;
            }
            @foreach (LeaderboardItemDto row in _items!)
            {
                var rowClass = GetRowCss(row);

                <tr class="@rowClass">
                    <td>@(++idx)</td>
                    <td>@row.FirstName @row.LastName</td>
                    <td>@row.Email</td>
                    <td><strong>@row.Score</strong></td>

                    <td>
                        @RenderStatus(row)
                    </td>

                    <td>
                        @if (row.FinishedAt.HasValue)
                        {
                            @row.FinishedAt.Value.ToLocalTime().ToString("g")
                        }
                        else
                        {
                            <span class="text-muted">–</span>
                        }
                    </td>

                    <td>
                        @if (row.ViolationCount > 0)
                        {
                            <span class="badge bg-warning text-dark">@row.ViolationCount</span>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>

                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => DownloadRecording(row.ExamSessionId)">
                            Kaydı indir
                        </button>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary"
                                @onclick="() => GoToDetail(row.ExamSessionId)">
                            Detay
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private int _take = 30;
    private LeaderboardItemDto[]? _items;

    protected override async Task OnInitializedAsync() => await Reload();

    private async Task Reload()
    {
        _items = null;
        _items = await ReportsApp.GetLeaderboardAsync(_take);
        StateHasChanged();
    }

    void GoToDetail(Guid id)
    {
        Nav.NavigateTo($"/admin/session/{id}");
    }

    private void DownloadRecording(Guid sessionId)
    {
        var url = $"/api/recordings/download?sessionId={sessionId}";
        Nav.NavigateTo(url, forceLoad: true);
    }

    // Satırın CSS sınıfını durumuna göre belirle
    private string GetRowCss(LeaderboardItemDto row)
    {
        if (row.IsCancelled)
        {
            return "table-danger";
        }

        if (row.FinishedAt.HasValue)
        {
            return "table-success";
        }

        return string.Empty;
    }

    // Durum text'i
    private RenderFragment RenderStatus(LeaderboardItemDto row) => builder =>
    {
        var status = row.IsCancelled
            ? "İptal"
            : (row.FinishedAt.HasValue ? "Tamamlandı" : "Devam Ediyor");

        var css = row.IsCancelled
            ? "badge bg-danger"
            : (row.FinishedAt.HasValue ? "badge bg-success" : "badge bg-secondary");

        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", css);
        builder.AddContent(2, status);
        builder.CloseElement();
    };
}
