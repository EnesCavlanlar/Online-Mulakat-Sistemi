@page "/admin/session/{SessionId:guid}"
@using DenemeTest.Application.Exams
@inject IReportsAppService ReportsApp
@inject NavigationManager Nav

<h3>Oturum Detayı</h3>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}

@if (_detail is null)
{
    <p>Yükleniyor...</p>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5>@_detail.CandidateFirstName @_detail.CandidateLastName</h5>

            <p><b>E-posta:</b> @_detail.CandidateEmail</p>

            @{
                var statusText = _detail.IsCancelled
                ? "İptal"
                : (_detail.EndTime.HasValue ? "Tamamlandı" : "Devam Ediyor");

                var statusCss = _detail.IsCancelled
                ? "badge bg-danger"
                : (_detail.EndTime.HasValue ? "badge bg-success" : "badge bg-secondary");

                var scoreCss = _detail.Score.HasValue
                ? (_detail.Score.Value >= 70 ? "badge bg-success" : _detail.Score.Value >= 40 ? "badge bg-warning text-dark" : "badge bg-danger")
                : "badge bg-secondary";

                var cacheKey = DateTimeOffset.Now.ToUnixTimeSeconds();

                var candidateVideoUrl = AppendCache(
                string.IsNullOrWhiteSpace(_detail.CandidateRecordingUrl)
                ? $"/api/recordings/download?sessionId={SessionId}&kind=cam"
                : _detail.CandidateRecordingUrl,
                cacheKey
                );

                var screenVideoUrl = AppendCache(
                string.IsNullOrWhiteSpace(_detail.ScreenRecordingUrl)
                ? $"/api/recordings/download?sessionId={SessionId}&kind=screen"
                : _detail.ScreenRecordingUrl,
                cacheKey
                );
            }

            <div class="row">
                <div class="col-md-6">
                    <p><b>Durum:</b> <span class="@statusCss">@statusText</span></p>
                    <p><b>Başlangıç:</b> @(_detail.StartTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</p>
                    <p><b>Bitiş:</b> @(_detail.EndTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</p>
                </div>

                <div class="col-md-6">
                    <p>
                        <b>Puan:</b>
                        <span class="@scoreCss">
                            @(_detail.Score.HasValue ? $"{_detail.Score}/100" : "Hesaplanmadı")
                        </span>
                    </p>

                    <p><b>İhlal sayısı:</b> @_detail.Violations</p>

                    @if (!string.IsNullOrWhiteSpace(_detail.ScoreExplanation))
                    {
                        <p><b>Puan açıklaması:</b> @_detail.ScoreExplanation</p>
                    }
                </div>
            </div>

            @if (_detail.IsCancelled && !string.IsNullOrWhiteSpace(_detail.CancelReason))
            {
                <div class="alert alert-danger mt-2">
                    <b>İptal sebebi:</b> @_detail.CancelReason
                </div>
            }

            <h5 class="mt-4">Sınav Kayıtları</h5>

            <div class="alert alert-info small">
                Burada adayın kamera görüntüsü ve adayın sınav sırasında paylaştığı cihaz ekran kaydı gösterilir.
                Video görünmüyorsa kayıt henüz yüklenmemiş, dosya boş oluşmuş veya tarayıcı önbelleği eski kayıt yolunu tutuyor olabilir.
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header">
                            <strong>Aday görüntüsü</strong>
                        </div>

                        <div class="card-body">
                            <p class="text-muted small mb-2">
                                Adayın kamera kaydı.
                            </p>

                            <video controls
                                   preload="metadata"
                                   style="width:100%;height:240px;border-radius:8px;background:#000"
                                   src="@candidateVideoUrl">
                                Tarayıcınız video oynatmayı desteklemiyor.
                            </video>

                            <div class="mt-3 d-flex gap-2 flex-wrap">
                                <a class="btn btn-sm btn-outline-primary"
                                   href="@candidateVideoUrl"
                                   target="_blank">
                                    Aday görüntüsünü aç
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@candidateVideoUrl"
                                   download>
                                    Aday görüntüsünü indir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header">
                            <strong>Cihaz ekran kaydı</strong>
                        </div>

                        <div class="card-body">
                            <p class="text-muted small mb-2">
                                Adayın sınav sırasında paylaştığı ekran kaydı.
                            </p>

                            <video controls
                                   preload="metadata"
                                   style="width:100%;height:240px;border-radius:8px;background:#000"
                                   src="@screenVideoUrl">
                                Tarayıcınız video oynatmayı desteklemiyor.
                            </video>

                            <div class="mt-3 d-flex gap-2 flex-wrap">
                                <a class="btn btn-sm btn-outline-primary"
                                   href="@screenVideoUrl"
                                   target="_blank">
                                    Cihaz ekran kaydını aç
                                </a>

                                <a class="btn btn-sm btn-outline-secondary"
                                   href="@screenVideoUrl"
                                   download>
                                    Cihaz ekran kaydını indir
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="mt-4">Proctoring İhlal Kayıtları</h5>

            @if (_detail.ProctoringEvents == null || !_detail.ProctoringEvents.Any())
            {
                <div class="alert alert-secondary">
                    Bu oturuma ait proctoring ihlal kaydı bulunamadı.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead>
                            <tr>
                                <th style="width:180px">Zaman</th>
                                <th style="width:180px">Tip</th>
                                <th>Detay</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in _detail.ProctoringEvents)
                            {
                                <tr>
                                    <td>@item.CreationTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>
                                        <span class="badge bg-danger">@item.Type</span>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Detail) ? "-" : item.Detail)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <div class="mt-3">
                <button class="btn btn-sm btn-outline-primary" @onclick="GoBack">
                    Listeye dön
                </button>
            </div>
        </div>
    </div>

    <h5>LLM Kod Analizi</h5>

    @if (_detail.CodeReviews == null || !_detail.CodeReviews.Any())
    {
        <div class="alert alert-secondary">
            Bu oturuma ait LLM kod analizi bulunamadı.
        </div>
    }
    else
    {
        @foreach (var review in _detail.CodeReviews)
        {
            var reviewCardCss = review.IsSuspicious
                ? "card mb-3 border-danger"
                : "card mb-3 border-success";

            var suspiciousBadgeCss = review.IsSuspicious
                ? "badge bg-danger"
                : "badge bg-success";

            var suspiciousText = review.IsSuspicious
                ? "Şüpheli"
                : "Normal";

            var testBadgeCss = review.TestsPassed
                ? "badge bg-success"
                : "badge bg-danger";

            var testText = review.TestsPassed
                ? "Testlerden geçti"
                : "Testlerden geçemedi";

            <div class="@reviewCardCss">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>LLM Kod Analizi</strong>

                    <div class="d-flex gap-2">
                        <span class="@testBadgeCss">@testText</span>
                        <span class="@suspiciousBadgeCss">@suspiciousText</span>
                    </div>
                </div>

                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(review.QuestionText))
                    {
                        <div class="mb-3">
                            <b>Soru:</b>
                            <div class="mt-1">@review.QuestionText</div>
                        </div>
                    }

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <b>Test sonucu:</b>
                            <div>@review.PassedCount / @review.TotalCount geçti</div>
                        </div>

                        <div class="col-md-3">
                            <b>Şüpheli mi?</b>
                            <div>
                                <span class="@suspiciousBadgeCss">@suspiciousText</span>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <b>Kalite puanı:</b>
                            <div>@(review.QualityScore.HasValue ? $"{review.QualityScore}/100" : "-")</div>
                        </div>

                        <div class="col-md-3">
                            <b>Provider:</b>
                            <div>@(string.IsNullOrWhiteSpace(review.Provider) ? "-" : review.Provider)</div>
                        </div>
                    </div>

                    @if (review.IsSuspicious)
                    {
                        <div class="alert alert-danger">
                            Bu çözüm LLM tarafından şüpheli işaretlendi. Aday doğru test sonucuna ulaşmış olsa bile çözüm manuel incelenmeli.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success">
                            Bu çözüm LLM tarafından normal görünüyor.
                        </div>
                    }

                    <div class="mb-3">
                        <b>Özet:</b>
                        <div class="alert alert-light border mt-2 mb-0">
                            @review.Summary
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(review.Flags))
                    {
                        <div class="mb-3">
                            <b>Etiketler:</b>

                            <div class="mt-2">
                                @foreach (var flag in SplitFlags(review.Flags))
                                {
                                    <span class="badge bg-secondary me-1 mb-1">@flag</span>
                                }
                            </div>
                        </div>
                    }

                    <p class="text-muted small mb-0">
                        Analiz zamanı: @review.CreationTime.ToString("yyyy-MM-dd HH:mm")
                    </p>
                </div>
            </div>
        }
    }

    <h5>Cevaplar</h5>

    @if (_detail.Answers == null || !_detail.Answers.Any())
    {
        <div class="alert alert-secondary">
            Bu oturuma ait cevap kaydı bulunamadı.
        </div>
    }
    else
    {
        @foreach (var ans in _detail.Answers)
        {
            var answerCardCss = ans.IsCorrect.HasValue
                ? (ans.IsCorrect.Value ? "card mb-2 border-success" : "card mb-2 border-danger")
                : "card mb-2";

            var answerBadgeCss = ans.IsCorrect.HasValue
                ? (ans.IsCorrect.Value ? "badge bg-success" : "badge bg-danger")
                : "badge bg-secondary";

            var answerBadgeText = ans.IsCorrect.HasValue
                ? (ans.IsCorrect.Value ? "Doğru" : "Yanlış")
                : "Manuel/Metinsel";

            <div class="@answerCardCss">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-2">
                        <h6>@ans.QuestionText</h6>

                        <div class="text-end">
                            <span class="@answerBadgeCss">@answerBadgeText</span>
                            <div class="small text-muted mt-1">@ans.QuestionPoints puan</div>
                        </div>
                    </div>

                    <p><b>Tip:</b> @ans.QuestionType</p>

                    @if (ans.SelectedOptions is not null)
                    {
                        <div class="mb-2">
                            <b>Seçilen cevap:</b>

                            @if (ans.SelectedOptions.Any())
                            {
                                <ul class="mb-0 mt-1">
                                    @foreach (var selected in ans.SelectedOptions)
                                    {
                                        <li>@selected</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted"> Cevap seçilmemiş.</span>
                            }
                        </div>
                    }

                    @if (ans.CorrectOptions is not null && ans.CorrectOptions.Any())
                    {
                        <div class="mb-2">
                            <b>Doğru cevap:</b>

                            <ul class="mb-0 mt-1">
                                @foreach (var correct in ans.CorrectOptions)
                                {
                                    <li>@correct</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(ans.TextAnswer))
                    {
                        if (ans.QuestionType.Equals("Coding", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="mb-2">
                                <b>Aday kodu:</b>
                                <pre class="bg-light p-2 rounded mt-2">@ans.TextAnswer</pre>
                            </div>
                        }
                        else
                        {
                            <div class="mb-2">
                                <b>Cevap:</b>
                                <div class="border rounded bg-light p-2 mt-1">
                                    @ans.TextAnswer
                                </div>
                            </div>
                        }
                    }
                    else if (ans.SelectedOptions == null || !ans.SelectedOptions.Any())
                    {
                        <div class="alert alert-secondary small mb-0">
                            Aday bu soru için cevap göndermemiş.
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(ans.CodeOutput))
                    {
                        <div class="alert alert-secondary">
                            <b>Kod Çıktısı:</b><br />
                            <pre class="mb-0">@ans.CodeOutput</pre>
                        </div>
                    }
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public Guid SessionId { get; set; }

    private SessionDetailDto? _detail;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _detail = await ReportsApp.GetSessionDetailAsync(SessionId);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/admin/reports");
    }

    private static string AppendCache(string url, long cacheKey)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return url;
        }

        return url.Contains('?')
            ? $"{url}&v={cacheKey}"
            : $"{url}?v={cacheKey}";
    }

    private static List<string> SplitFlags(string? flags)
    {
        if (string.IsNullOrWhiteSpace(flags))
        {
            return new List<string>();
        }

        return flags
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToList();
    }
}