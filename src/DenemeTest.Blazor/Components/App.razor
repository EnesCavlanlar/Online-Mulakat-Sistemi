@using System.Globalization
@using Microsoft.Extensions.Hosting
@using Volo.Abp.AspNetCore.Components.Server.LeptonXLiteTheme.Bundling
@using Volo.Abp.Localization
@using Volo.Abp.AspNetCore.Components.Web.Theming.Bundling
@inject IHostEnvironment Env

@{
    var rtl = CultureHelper.IsRtl ? "rtl" : string.Empty;
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentCulture.Name" dir="@rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DenemeTest</title>
    <base href="/" />

    <AbpStyles BundleName="@BlazorLeptonXLiteThemeBundles.Styles.Global" />

    <link href="DenemeTest.Blazor.styles.css" rel="stylesheet" />

    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body class="abp-application-layout @rtl">

    <Routes @rendermode="InteractiveServer" />

    <div id="blazor-error-ui">
        @if (Env.IsDevelopment())
        {
            <text>An unhandled exception has occurred. See browser dev tools for details.</text>
        }
        else if (Env.IsStaging() || Env.IsProduction())
        {
            <text>An error has occurred. This application may no longer respond until reloaded.</text>
        }

        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <AbpScripts BundleName="@BlazorLeptonXLiteThemeBundles.Scripts.Global" />

    <script src="/js/exam-media.js?v=12"></script>
    <script src="/js/examProctor.js?v=12"></script>
    <script src="/js/recorder.js?v=12"></script>
    <script src="/js/codeEditor.js?v=1"></script>

    <script>
        window.examRunner = window.examRunner || {
            closeWindow: function () {
                try {
                    window.close();
                } catch (e) {
                }

                setTimeout(function () {
                    try {
                        window.location.href = "/exam/finished";
                    } catch (e) {
                    }
                }, 1500);
            }
        };

        window.checkExamModules = function () {
            return {
                mediaGateLoaded: !!window.mediaGate,
                requestCamLoaded: !!(window.mediaGate && typeof window.mediaGate.requestCam === "function"),
                requestScreenLoaded: !!(window.mediaGate && typeof window.mediaGate.requestScreen === "function"),
                stopPreviewLoaded: !!(window.mediaGate && typeof window.mediaGate.stopPreview === "function"),

                examProctorLoaded: !!window.examProctor,
                startProctorLoaded: !!(window.examProctor && typeof window.examProctor.start === "function"),
                stopProctorLoaded: !!(window.examProctor && typeof window.examProctor.stop === "function"),

                examRecorderLoaded: !!window.examRecorder,
                startRecorderLoaded: !!(window.examRecorder && typeof window.examRecorder.start === "function"),
                stopRecorderLoaded: !!(window.examRecorder && typeof window.examRecorder.stop === "function")
            };
        };

        window.forceStopExamMedia = function () {
            try {
                if (window.examRecorder && typeof window.examRecorder.stop === "function") {
                    window.examRecorder.stop();
                }
            } catch (e) {
                console.warn("examRecorder stop error", e);
            }

            try {
                if (window.examProctor && typeof window.examProctor.stop === "function") {
                    window.examProctor.stop();
                }
            } catch (e) {
                console.warn("examProctor stop error", e);
            }

            try {
                if (window.mediaGate && typeof window.mediaGate.stopPreview === "function") {
                    window.mediaGate.stopPreview("camPreview");
                    window.mediaGate.stopPreview("screenPreview");
                }
            } catch (e) {
                console.warn("mediaGate stopPreview error", e);
            }
        };
    </script>

    <script src="_framework/blazor.web.js"></script>

</body>
</html>