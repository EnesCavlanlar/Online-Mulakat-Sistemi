@inherits LayoutComponentBase

<div class="exam-container">
    @Body
</div>

<style>
    .sidebar, .top-row, nav, .navbar, .app-navbar, .layout-main, .main-menu,
    .menu, .main, .app-main, header, footer {
        display: none !important;
    }

    html, body {
        width: 100%;
        height: 100%;
        margin: 0;
        padding: 0;
        background: #f5f5f5;
    }

    .exam-container {
        min-height: 100vh;
    }
</style>

<!-- ÖNEMLİ: examProctor JS mutlaka yüklensin ve öncelikli olsun -->
<script src="/js/exam-media.js?v=4"></script>
<script src="/js/examProctor.js?v=4"></script>
<script src="/js/exam.js?v=4"></script>
<script src="/js/recorder.js?v=4"></script>

<script>
    // Kapanış için tarafsız fallback (admin'e yönlendirme yok)
    window.examRunner = window.examRunner || {
      closeWindow: function () {
        try { window.close(); } catch (e) {}
        setTimeout(function () { try { window.location.href = "/exam/finished"; } catch (e) {} }, 1500);
      }
    };
</script>
